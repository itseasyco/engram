#!/usr/bin/env bash
set -euo pipefail

# Resolve version from package.json relative to this script
_script_source="${BASH_SOURCE[0]}"
while [ -L "$_script_source" ]; do
    _script_dir="$(cd -P "$(dirname "$_script_source")" && pwd)"
    _script_source="$(readlink "$_script_source")"
    [[ "$_script_source" != /* ]] && _script_source="$_script_dir/$_script_source"
done
_pkg_json="$(cd -P "$(dirname "$_script_source")/.." && pwd)/package.json"
VERSION=$(node -p "try{require('${_pkg_json}').version}catch(e){'3.0.0'}" 2>/dev/null || echo "3.0.0")

# Resolve the real location of this script (follow npm link symlinks)
_resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    local dir
    # Follow symlink chain
    while [ -L "$source" ]; do
        dir="$(cd -P "$(dirname "$source")" && pwd)"
        source="$(readlink "$source")"
        # Handle relative symlinks
        [[ "$source" != /* ]] && source="$dir/$source"
    done
    cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(_resolve_script_dir)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Find plugin bin: repo structure (plugin/bin) or installed extension
if [ -d "$ROOT_DIR/plugin/bin" ]; then
    PLUGIN_BIN="$ROOT_DIR/plugin/bin"
elif [ -d "$HOME/.openclaw/extensions/engram/bin" ]; then
    PLUGIN_BIN="$HOME/.openclaw/extensions/engram/bin"
else
    echo "Error: Cannot find Engram plugin bin directory" >&2
    exit 1
fi

if [ -f "$ROOT_DIR/INSTALL.sh" ]; then
    INSTALL_SH="$ROOT_DIR/INSTALL.sh"
else
    INSTALL_SH=""
fi

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

show_banner() {
    echo ""
    echo -e "${BOLD}${CYAN}"
    echo "  ███████╗███╗   ██╗ ██████╗ ██████╗  █████╗ ███╗   ███╗"
    echo "  ██╔════╝████╗  ██║██╔════╝ ██╔══██╗██╔══██╗████╗ ████║"
    echo "  █████╗  ██╔██╗ ██║██║  ███╗██████╔╝███████║██╔████╔██║"
    echo "  ██╔══╝  ██║╚██╗██║██║   ██║██╔══██╗██╔══██║██║╚██╔╝██║"
    echo "  ███████╗██║ ╚████║╚██████╔╝██║  ██║██║  ██║██║ ╚═╝ ██║"
    echo "  ╚══════╝╚═╝  ╚═══╝ ╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═╝╚═╝     ╚═╝"
    echo -e "${NC}"
    echo -e "  ${DIM}Shared Intelligence Graph for AI Agents${NC}"
    echo -e "  ${DIM}v${VERSION}${NC}"
    echo ""
    echo -e "  ${DIM}by${NC}"
    echo -e "  ${BOLD}${DIM}      ___  __ _ ____  _   |  __ _| |__ ___${NC}"
    echo -e "  ${BOLD}${DIM}     / -_)/ _\` (_-< || |  | / _\` | '_ (_-<${NC}"
    echo -e "  ${BOLD}${DIM}     \\___|\\__,_/__/\\_, |  |_\\__,_|_.__/__/${NC}"
    echo -e "  ${BOLD}${DIM}                   |__/    itseasy.co${NC}"
    echo ""
}

show_help() {
    show_banner
    echo -e "${BOLD}USAGE${NC}"
    echo "  engram <command> [options]"
    echo ""
    echo -e "${BOLD}COMMANDS${NC}"
    echo -e "  ${GREEN}wizard${NC}              Interactive setup wizard"
    echo -e "  ${GREEN}status${NC}              System overview"
    echo -e "  ${GREEN}doctor${NC}              Full diagnostics (plugin, layers, MCP)"
    echo ""
    echo -e "${BOLD}MEMORY${NC}"
    echo -e "  ${GREEN}memory query${NC} <topic>    Search memory              ${DIM}(→ engram-context)${NC}"
    echo -e "  ${GREEN}memory promote${NC}          Promote facts              ${DIM}(→ engram-promote)${NC}"
    echo -e "  ${GREEN}memory status${NC}           Memory dashboard           ${DIM}(→ engram-memory-status)${NC}"
    echo ""
    echo -e "${BOLD}GUARD${NC}"
    echo -e "  ${GREEN}guard rules${NC}             List rules                 ${DIM}(engram guard rules)${NC}"
    echo -e "  ${GREEN}guard blocks${NC}            Recent blocks              ${DIM}(engram guard blocks)${NC}"
    echo -e "  ${GREEN}guard toggle${NC} <id>       Toggle rule                ${DIM}(engram guard toggle npm-publish)${NC}"
    echo -e "  ${GREEN}guard allow/deny${NC} \"<cmd>\" Allowlist management      ${DIM}(engram guard allow \"git reset\")${NC}"
    echo -e "  ${GREEN}guard config${NC}            Interactive config"
    echo ""
    echo -e "${BOLD}VAULT${NC}"
    echo -e "  ${GREEN}vault status${NC}            Vault health               ${DIM}(→ engram-obsidian status)${NC}"
    echo -e "  ${GREEN}vault audit${NC}             Full audit                 ${DIM}(→ engram-obsidian audit)${NC}"
    echo -e "  ${GREEN}vault backup${NC}            Backup vault"
    echo -e "  ${GREEN}vault restore${NC}           Restore from backup"
    echo -e "  ${GREEN}vault optimize${NC}          Graph physics              ${DIM}(→ engram-obsidian-optimize)${NC}"
    echo -e "  ${GREEN}vault kpi${NC}               Quality KPIs               ${DIM}(→ engram-memory-kpi)${NC}"
    echo -e "  ${GREEN}vault heal${NC}              Vault doctor               ${DIM}(→ vault_doctor.py)${NC}"
    echo -e "  ${GREEN}vault migrate${NC}           Structure migration        ${DIM}(→ engram-vault-migrate)${NC}"
    echo ""
    echo -e "${BOLD}BRAIN${NC}"
    echo -e "  ${GREEN}brain expand${NC}            Layer expansion (default)"
    echo -e "  ${GREEN}brain expand${NC} --consolidate  Mycelium consolidation"
    echo -e "  ${GREEN}brain expand${NC} --curator-cycle Full 8-step maintenance"
    echo -e "  ${GREEN}brain graph${NC}             Knowledge graph ops        ${DIM}(init|index|query)${NC}"
    echo -e "  ${GREEN}brain code${NC}              AST analysis"
    echo -e "  ${GREEN}brain resolve${NC}           Contradiction resolution"
    echo ""
    echo -e "${BOLD}INGEST${NC}"
    echo -e "  ${GREEN}ingest${NC} <type> <source>  Ingest content             ${DIM}(transcript|url|pdf|file|video|audio)${NC}"
    echo ""
    echo -e "${BOLD}MANAGEMENT${NC}"
    echo -e "  ${GREEN}uninstall${NC}           Remove Engram (preserves vault data)"
    echo ""
    echo -e "${BOLD}OPTIONS${NC}"
    echo "  -h, --help          Show this help"
    echo "  -v, --version       Show version"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo "  engram wizard                          # Full interactive setup"
    echo "  engram status                          # System overview"
    echo "  engram doctor                          # Run all diagnostics"
    echo "  engram memory query payment            # Search memory for payment facts"
    echo "  engram guard rules                     # List all guard rules"
    echo "  engram vault status                    # Vault health check"
    echo "  engram vault kpi                       # Vault quality metrics"
    echo "  engram brain expand --consolidate      # Run mycelium consolidation"
    echo "  engram ingest video meeting.mp4        # Ingest a video file"
    echo ""
    echo -e "${BOLD}COMING SOON${NC}"
    echo -e "  ${DIM}connect, disconnect, connector, watch${NC}"
    echo ""
}

cmd_wizard() {
    local section="all"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --section) section="$2"; shift 2 ;;
            -h|--help)
                echo "Usage: engram wizard [--section <name>]"
                echo ""
                echo "Sections: vault, engine, profile, mode, guard, dependencies, all"
                exit 0
                ;;
            *) echo -e "${RED}Unknown option: $1${NC}"; exit 1 ;;
        esac
    done

    if [[ "$section" = "guard" ]]; then
        exec "$PLUGIN_BIN/engram-guard" config
    fi

    # Run Node.js interactive wizard (outputs config to /tmp/engram-wizard-config.json)
    local wizard_mjs="$ROOT_DIR/bin/wizard.mjs"
    local wizard_config="/tmp/engram-wizard-config.json"

    if [[ -f "$wizard_mjs" ]]; then
        # Run the Node wizard; if it exits non-zero (user cancelled), propagate
        node "$wizard_mjs" || exit $?

        if [[ ! -f "$wizard_config" ]]; then
            # Wizard handled everything directly (Claude Code / Codex only)
            exit 0
        fi

        # Check if OpenClaw was selected — only then run INSTALL.sh
        local has_openclaw
        has_openclaw=$(node -p "
            var c = JSON.parse(require('fs').readFileSync('$wizard_config','utf8'));
            (c.platforms || []).includes('openclaw') ? 'yes' : 'no'
        " 2>/dev/null || echo "no")

        if [[ "$has_openclaw" = "yes" ]]; then
            if [[ ! -f "$INSTALL_SH" ]]; then
                echo -e "${RED}INSTALL.sh not found at $INSTALL_SH${NC}"
                echo "Run engram from the repo directory or install globally via npm install -g engram"
                exit 1
            fi
            # Hand off to INSTALL.sh for OpenClaw-specific setup
            exec bash "$INSTALL_SH" --from-config "$wizard_config"
        else
            # Non-OpenClaw install complete — wizard handled Claude Code / Codex directly
            exit 0
        fi
    else
        # Fallback: no Node wizard available, run legacy interactive INSTALL.sh
        echo -e "${YELLOW}Node wizard not found at $wizard_mjs — falling back to legacy prompts.${NC}"
        echo ""

        # TODO: section-specific wizard runs (for now, run full wizard)
        if [[ "$section" != "all" ]]; then
            echo -e "${YELLOW}Section-specific wizard not yet implemented.${NC}"
            echo -e "Running full wizard. Use arrow keys to skip sections you don't want to change."
            echo ""
        fi

        exec bash "$INSTALL_SH"
    fi
}

_source_env_config() {
    # Source the LACP env config so env vars are available to subcommands
    local env_file="$HOME/.openclaw/extensions/engram/config/.engram.env"
    if [[ -f "$env_file" ]]; then
        while IFS= read -r line; do
            line="${line%%#*}"  # strip comments
            line="${line#"${line%%[![:space:]]*}"}"  # trim leading whitespace
            [[ -z "$line" ]] && continue
            if [[ "$line" == *=* ]]; then
                local key="${line%%=*}"
                local val="${line#*=}"
                # Only export if not already set in environment
                if [[ -z "${!key:-}" ]]; then
                    export "$key=$val"
                fi
            fi
        done < "$env_file"
    fi
}

cmd_status() {
    _source_env_config
    show_banner

    echo -e "${BOLD}System Status${NC}"
    echo ""

    # Mode
    local mode
    mode=$(python3 -c "
import sys, os
sys.path.insert(0, os.path.expanduser('~/.openclaw/extensions/engram/lib'))
try:
    from mode import get_config
    c = get_config()
    print(f'mode={c.mode} mutations={c.mutations_enabled} vault={c.vault_path}')
except Exception as e:
    print(f'error={e}')
" 2>/dev/null || echo "mode=unknown")

    echo -e "  ${BOLD}Mode:${NC}         $(echo "$mode" | grep -o 'mode=[^ ]*' | cut -d= -f2)"
    echo -e "  ${BOLD}Mutations:${NC}    $(echo "$mode" | grep -o 'mutations=[^ ]*' | cut -d= -f2)"
    echo -e "  ${BOLD}Vault:${NC}        $(echo "$mode" | grep -o 'vault=.*' | cut -d= -f2)"
    echo ""

    # Plugin
    if [[ -f ~/.openclaw/extensions/engram/index.ts ]]; then
        echo -e "  ${GREEN}+${NC} Plugin installed"
    else
        echo -e "  ${RED}-${NC} Plugin not installed"
    fi

    # Guard
    if [[ -f ~/.openclaw/extensions/engram/config/guard-rules.json ]]; then
        local rule_count
        rule_count=$(python3 -c "import json; d=json.load(open(os.path.expanduser('~/.openclaw/extensions/engram/config/guard-rules.json'))); print(len(d.get('rules',[])))" 2>/dev/null || echo "?")
        echo -e "  ${GREEN}+${NC} Guard active ($rule_count rules)"
    else
        echo -e "  ${YELLOW}~${NC} Guard using factory defaults"
    fi

    # Vault
    local vault_path
    vault_path=$(echo "$mode" | grep -o 'vault=.*' | cut -d= -f2)
    if [[ -n "$vault_path" ]] && [[ -d "$vault_path" ]]; then
        local note_count
        note_count=$(find "$vault_path" -name "*.md" -not -path "*/.obsidian/*" 2>/dev/null | wc -l | tr -d ' ')
        echo -e "  ${GREEN}+${NC} Vault: $note_count notes"
    else
        echo -e "  ${YELLOW}~${NC} Vault not found or not configured"
    fi

    # ob sync
    if command -v ob &>/dev/null; then
        echo -e "  ${GREEN}+${NC} obsidian-headless installed"
    else
        echo -e "  ${DIM}-${NC} obsidian-headless not installed"
    fi

    # Tool log
    local log_file=~/.openclaw/extensions/engram/logs/tool-calls.jsonl
    if [[ -f "$log_file" ]]; then
        local call_count
        call_count=$(wc -l < "$log_file" | tr -d ' ')
        echo -e "  ${GREEN}+${NC} Tool log: $call_count entries"
    fi

    echo ""
}

cmd_doctor() {
    _source_env_config
    show_banner
    echo -e "${BOLD}Running diagnostics...${NC}"
    echo ""

    local pass=0
    local fail=0
    local warn=0

    # ── Plugin Infrastructure ────────────────────────────────────────────
    echo -e "  ${BLUE}Plugin Infrastructure${NC}"

    # Check plugin
    if [[ -f ~/.openclaw/extensions/engram/index.ts ]]; then
        echo -e "  ${GREEN}pass${NC}  Plugin index.ts exists"
        ((pass++))
    else
        echo -e "  ${RED}FAIL${NC}  Plugin index.ts missing"
        ((fail++))
    fi

    # Check package.json
    if [[ -f ~/.openclaw/extensions/engram/package.json ]]; then
        echo -e "  ${GREEN}pass${NC}  package.json exists"
        ((pass++))
    else
        echo -e "  ${RED}FAIL${NC}  package.json missing"
        ((fail++))
    fi

    # Check SDK symlink
    if [[ -d ~/.openclaw/extensions/engram/node_modules/openclaw ]] || [[ -L ~/.openclaw/extensions/engram/node_modules/openclaw ]]; then
        echo -e "  ${GREEN}pass${NC}  OpenClaw SDK linked"
        ((pass++))
    else
        echo -e "  ${RED}FAIL${NC}  OpenClaw SDK not linked"
        ((fail++))
    fi

    # Check hooks
    for hook in session-start pretool-guard stop-quality-gate write-validate; do
        if [[ -f ~/.openclaw/extensions/engram/hooks/handlers/${hook}.py ]]; then
            echo -e "  ${GREEN}pass${NC}  Hook: ${hook}"
            ((pass++))
        else
            echo -e "  ${RED}FAIL${NC}  Hook missing: ${hook}"
            ((fail++))
        fi
    done

    # Check lib modules
    for mod in mycelium consolidation review_queue knowledge_gaps mode heartbeat; do
        if [[ -f ~/.openclaw/extensions/engram/lib/${mod}.py ]]; then
            echo -e "  ${GREEN}pass${NC}  Module: ${mod}"
            ((pass++))
        else
            echo -e "  ${YELLOW}warn${NC}  Module missing: ${mod}"
            ((warn++))
        fi
    done

    # Check guard config
    if [[ -f ~/.openclaw/extensions/engram/config/guard-rules.json ]]; then
        echo -e "  ${GREEN}pass${NC}  Guard config"
        ((pass++))
    else
        echo -e "  ${YELLOW}warn${NC}  Guard config missing (using factory defaults)"
        ((warn++))
    fi

    # ── Layer 1: Session Memory ──────────────────────────────────────────
    echo ""
    echo -e "  ${BLUE}Layer 1: Session Memory${NC}"

    local session_root="${SESSION_MEMORY_ROOT:-$HOME/.openclaw/projects}"
    if [[ -d "$session_root" ]]; then
        local project_count
        project_count=$(find "$session_root" -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
        echo -e "  ${GREEN}pass${NC}  Session root exists ($((project_count - 1)) projects)"
        ((pass++))
    else
        echo -e "  ${YELLOW}warn${NC}  Session root not found at $session_root"
        ((warn++))
    fi

    # ── Layer 2: Knowledge Graph ─────────────────────────────────────────
    echo ""
    echo -e "  ${BLUE}Layer 2: Knowledge Graph${NC}"

    local vault_path="${LACP_OBSIDIAN_VAULT:-${OPENCLAW_VAULT:-}}"
    if [[ -n "$vault_path" ]] && [[ -d "$vault_path" ]]; then
        echo -e "  ${GREEN}pass${NC}  Obsidian vault exists at $vault_path"
        ((pass++))

        for dir_name in projects engineering knowledge inbox; do
            if [[ -d "$vault_path/$dir_name" ]]; then
                echo -e "  ${GREEN}pass${NC}  $dir_name/"
                ((pass++))
            else
                echo -e "  ${YELLOW}warn${NC}  $dir_name/ (missing)"
                ((warn++))
            fi
        done
    else
        echo -e "  ${YELLOW}warn${NC}  Obsidian vault not found or not configured"
        ((warn++))
    fi

    if command -v qmd &>/dev/null; then
        echo -e "  ${GREEN}pass${NC}  QMD available"
        ((pass++))
    else
        echo -e "  ${YELLOW}warn${NC}  QMD not installed (optional)"
        ((warn++))
    fi

    # ── Layer 3: Ingestion Pipeline ──────────────────────────────────────
    echo ""
    echo -e "  ${BLUE}Layer 3: Ingestion Pipeline${NC}"

    if [[ -x "$PLUGIN_BIN/engram-brain-ingest" ]]; then
        echo -e "  ${GREEN}pass${NC}  engram-brain-ingest available"
        ((pass++))
    else
        echo -e "  ${YELLOW}warn${NC}  engram-brain-ingest not found"
        ((warn++))
    fi

    if command -v ffmpeg &>/dev/null; then
        echo -e "  ${GREEN}pass${NC}  ffmpeg available"
        ((pass++))
    else
        echo -e "  ${YELLOW}warn${NC}  ffmpeg not installed (optional, for video/audio)"
        ((warn++))
    fi

    # ── Layer 4: Code Intelligence ───────────────────────────────────────
    echo ""
    echo -e "  ${BLUE}Layer 4: Code Intelligence${NC}"

    if [[ -x "$PLUGIN_BIN/engram-brain-code" ]]; then
        echo -e "  ${GREEN}pass${NC}  engram-brain-code available"
        ((pass++))
    else
        echo -e "  ${YELLOW}warn${NC}  engram-brain-code not found"
        ((warn++))
    fi

    if command -v gitnexus &>/dev/null; then
        echo -e "  ${GREEN}pass${NC}  GitNexus available"
        ((pass++))
    else
        echo -e "  ${YELLOW}warn${NC}  GitNexus not installed (optional)"
        ((warn++))
    fi

    # ── Layer 5: Agent Identity & Provenance ─────────────────────────────
    echo ""
    echo -e "  ${BLUE}Layer 5: Agent Identity & Provenance${NC}"

    local agent_store="${AGENT_ID_STORE:-$HOME/.openclaw/agent-ids}"
    if [[ -d "$agent_store" ]]; then
        local id_count
        id_count=$(find "$agent_store" -name "*.json" 2>/dev/null | wc -l | tr -d ' ')
        echo -e "  ${GREEN}pass${NC}  Agent ID store: $id_count identities"
        ((pass++))
    else
        echo -e "  ${YELLOW}warn${NC}  Agent ID store not found"
        ((warn++))
    fi

    local prov_root="${PROVENANCE_ROOT:-$HOME/.openclaw/provenance}"
    if [[ -d "$prov_root" ]]; then
        echo -e "  ${GREEN}pass${NC}  Provenance root exists"
        ((pass++))
    else
        echo -e "  ${YELLOW}warn${NC}  Provenance root not found"
        ((warn++))
    fi

    # ── MCP Connectivity ─────────────────────────────────────────────────
    echo ""
    echo -e "  ${BLUE}MCP Connectivity${NC}"

    for tool in qmd obsidian web_fetch; do
        if command -v "$tool" &>/dev/null; then
            echo -e "  ${GREEN}pass${NC}  $tool"
            ((pass++))
        else
            echo -e "  ${YELLOW}warn${NC}  $tool (not available)"
            ((warn++))
        fi
    done

    # ── Tests ────────────────────────────────────────────────────────────
    echo ""
    echo -e "  ${DIM}Running test suite...${NC}"
    local test_result
    test_result=$(cd "$ROOT_DIR" && python3 -m pytest plugin/lib/tests/test_mycelium.py -q 2>&1 | tail -1)
    if echo "$test_result" | grep -q "passed"; then
        echo -e "  ${GREEN}pass${NC}  Mycelium tests: $test_result"
        ((pass++))
    else
        echo -e "  ${RED}FAIL${NC}  Mycelium tests: $test_result"
        ((fail++))
    fi

    echo ""
    echo -e "  ${BOLD}Results: ${pass} passed, ${fail} failed, ${warn} warnings${NC}"
    echo ""

    [[ "$fail" -gt 0 ]] && exit 1
    exit 0
}

# ─── Main router ──────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
    show_help
    exit 1
fi

case "$1" in
    wizard|configure)
        shift
        cmd_wizard "$@"
        ;;
    status)
        cmd_status
        ;;
    doctor)
        cmd_doctor
        ;;
    # COMING SOON — connected mode (connect/disconnect)
    connect)
        echo -e "${YELLOW}Coming soon:${NC} engram connect (shared vault support)"
        echo "Follow progress at https://github.com/itseasyco/engram"
        exit 0
        ;;
    disconnect)
        echo -e "${YELLOW}Coming soon:${NC} engram disconnect (shared vault support)"
        exit 0
        ;;
    guard)
        shift
        exec "$PLUGIN_BIN/engram-guard" "$@"
        ;;
    memory)
        shift
        subcmd="${1:-}"; shift || true
        case "$subcmd" in
            query)   exec "$PLUGIN_BIN/engram-context" query --topic "$@" ;;
            promote) exec "$PLUGIN_BIN/engram-promote" "$@" ;;
            status)  exec "$PLUGIN_BIN/engram-memory-status" "$@" ;;
            *)       echo "Usage: engram memory <query|promote|status> [args]"; exit 1 ;;
        esac
        ;;
    ingest)
        shift
        exec "$PLUGIN_BIN/engram-brain-ingest" "$@"
        ;;
    brain)
        shift
        subcmd="${1:-}"; shift || true
        case "$subcmd" in
            expand)   exec "$PLUGIN_BIN/engram-brain-expand" "$@" ;;
            resolve)  exec "$PLUGIN_BIN/engram-brain-resolve" "$@" ;;
            code)     exec "$PLUGIN_BIN/engram-brain-code" "$@" ;;
            graph)    exec "$PLUGIN_BIN/engram-brain-graph" "$@" ;;
            *)        echo "Usage: engram brain <expand|resolve|code|graph> [args]"; exit 1 ;;
        esac
        ;;
    vault)
        shift
        case "${1:-}" in
            status)   shift; exec "$PLUGIN_BIN/engram-obsidian" status "$@" ;;
            audit)    shift; exec "$PLUGIN_BIN/engram-obsidian" audit "$@" ;;
            backup)   shift; exec "$PLUGIN_BIN/engram-obsidian" backup "$@" ;;
            restore)  shift; exec "$PLUGIN_BIN/engram-obsidian" restore "$@" ;;
            optimize) shift; exec "$PLUGIN_BIN/engram-obsidian-optimize" "$@" ;;
            kpi)      shift; exec "$PLUGIN_BIN/engram-memory-kpi" "$@" ;;
            heal)
                shift
                _source_env_config
                exec python3 "$(dirname "$PLUGIN_BIN")/lib/vault_doctor.py" "${LACP_OBSIDIAN_VAULT:-${OPENCLAW_VAULT:-$HOME/.openclaw/data/knowledge}}" "$@"
                ;;
            migrate)  shift; exec python3 "$PLUGIN_BIN/engram-vault-migrate" "$@" ;;
            *)        echo "Usage: engram vault <status|audit|backup|restore|optimize|kpi|heal|migrate>"; exit 1 ;;
        esac
        ;;
    # COMING SOON — connector management
    connector)
        echo -e "${YELLOW}Coming soon:${NC} engram connector (external integrations)"
        echo "Follow progress at https://github.com/itseasyco/engram"
        exit 0
        ;;
    # COMING SOON — file watcher
    watch)
        echo -e "${YELLOW}Coming soon:${NC} engram watch (file watcher for auto-ingestion)"
        echo "Follow progress at https://github.com/itseasyco/engram"
        exit 0
        ;;
    uninstall)
        shift
        echo ""
        echo -e "${BOLD}Engram Uninstall${NC}"
        echo ""

        # Find what's installed
        ext_dir=""
        if [ -d "$HOME/.openclaw/extensions/engram" ]; then
            ext_dir="$HOME/.openclaw/extensions/engram"
        elif [ -d "$HOME/.openclaw/extensions/engram" ]; then
            ext_dir="$HOME/.openclaw/extensions/engram"
        fi

        hook_dir="$HOME/.openclaw/hooks/engram-session-capture"

        echo "  This will remove:"
        if [ -n "$ext_dir" ]; then
            echo "    - Plugin: $ext_dir"
        fi
        if [ -d "$hook_dir" ]; then
            echo "    - Hook: $hook_dir"
        fi
        echo "    - Gateway config entries for engram/engram"
        echo ""
        echo -e "  ${DIM}Your vault data (Cortex) will NOT be deleted.${NC}"
        echo -e "  ${DIM}Your LACP memory files will NOT be deleted.${NC}"
        echo ""

        if [ "${1:-}" = "--yes" ] || [ "${1:-}" = "-y" ]; then
            :
        else
            echo -en "  Proceed with uninstall? [y/N]: "
            read -r confirm
            case "$confirm" in
                [yY]|[yY][eE][sS]) ;;
                *) echo "  Cancelled."; exit 0 ;;
            esac
        fi

        echo ""

        # Remove plugin extension
        if [ -n "$ext_dir" ] && [ -d "$ext_dir" ]; then
            rm -rf "$ext_dir"
            echo -e "  ${GREEN}✓${NC} Removed $ext_dir"
        fi

        # Remove managed hook
        if [ -d "$hook_dir" ]; then
            rm -rf "$hook_dir"
            echo -e "  ${GREEN}✓${NC} Removed $hook_dir"
        fi

        # Clean gateway config
        if command -v jq &>/dev/null && [ -f "$HOME/.openclaw/openclaw.json" ]; then
            tmp=""
            tmp=$(mktemp)
            jq '
                del(.plugins.entries["engram"]) |
                del(.plugins.entries["engram"]) |
                .plugins.allow = [.plugins.allow[] | select(. != "engram" and . != "engram")] |
                del(.plugins.installs["engram"]) |
                del(.plugins.installs["engram"]) |
                del(.hooks.internal.entries["engram-session-capture"])
            ' "$HOME/.openclaw/openclaw.json" > "$tmp" && mv "$tmp" "$HOME/.openclaw/openclaw.json"
            echo -e "  ${GREEN}✓${NC} Cleaned gateway config"
        else
            echo -e "  ${YELLOW}!${NC} Could not clean gateway config (jq not found). Edit ~/.openclaw/openclaw.json manually."
        fi

        # Unlink npm global
        npm unlink -g @easylabs/engram 2>/dev/null && echo -e "  ${GREEN}✓${NC} Unlinked npm global" || true

        echo ""
        echo -e "  ${GREEN}Engram uninstalled.${NC} Restart OpenClaw: openclaw gateway restart"
        echo ""
        ;;
    -v|--version)
        echo "engram v${VERSION}"
        ;;
    -h|--help|help)
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo ""
        show_help
        exit 1
        ;;
esac
