# ============================================================================
# OpenClaw LACP Fusion — Full Configuration Template
# Version: 2.0.0
#
# Copy to: ~/.openclaw/extensions/openclaw-lacp-fusion/config/.openclaw-lacp.env
# All values shown are defaults. Uncomment and modify to override.
#
# Auto-detected values are marked with [AUTO]. These are set by INSTALL.sh
# based on your OS and directory layout. Edit if the defaults are wrong.
# ============================================================================

# ============================================================================
# Layer 1: Session Memory
# ============================================================================
# Where per-project session memory is stored
# SESSION_MEMORY_ROOT=~/.openclaw/data/project-sessions

# Initialize git in new session directories
# MEMORY_SCAFFOLD_WITH_GIT=true

# Archive sessions older than N days
# MEMORY_ARCHIVE_KEEP_DAYS=90

# Custom templates for memory scaffolding
# SESSION_MEMORY_TEMPLATE_PATH=~/.openclaw/templates

# ============================================================================
# Layer 2: Knowledge Graph  [AUTO]
# ============================================================================
# Path to Obsidian vault (auto-detected by INSTALL.sh)
# LACP_OBSIDIAN_VAULT=~/obsidian/vault

# Knowledge graph data directory
# LACP_KNOWLEDGE_ROOT=~/.openclaw/data/knowledge

# Automation data directory
# LACP_AUTOMATION_ROOT=~/.openclaw/data/automation

# Auto-sync knowledge graph on changes
# KG_AUTO_SYNC=true

# Embedding backend for semantic search
# KG_EMBED_BACKEND=openai
# KG_EMBED_MODEL=text-embedding-3-small
# KG_SEMANTIC_SEARCH_ENABLED=true

# Sync knowledge graph to GitHub (requires repo setup)
# KG_GITHUB_SYNC=false

# ============================================================================
# Layer 3: Ingestion Pipeline
# ============================================================================
# Watch directory for new files to ingest
# INGEST_WATCH_DIR=/Volumes/Cortex/06-inbox

# Polling interval for new files
# INGEST_POLL_INTERVAL=6h

# Auto-link ingested content to existing knowledge
# INGEST_AUTO_LINK=true

# Chunk size for large documents
# INGEST_CHUNK_SIZE=2000

# Keep processed files (vs. delete after ingest)
# INGEST_KEEP_PROCESSED=true
# INGEST_PROCESSED_DIR=~/inbox/.processed

# Transcript handling
# INGEST_TRANSCRIPT_SPEAKER_DEFAULT=Unknown

# URL fetch timeout (seconds)
# INGEST_URL_FETCH_TIMEOUT=30

# PDF handling
# INGEST_PDF_EXTRACT_IMAGES=false
# INGEST_PDF_OCR_ENABLED=false

# ============================================================================
# Layer 4: Code Intelligence (Optional)
# ============================================================================
# Enable AST analysis, call graphs, impact analysis
# CODE_GRAPH_ENABLED=false

# Enable GitNexus integration (requires gitnexus binary)
# CODE_GRAPH_WITH_GITNEXUS=false

# Code graph storage
# CODE_GRAPH_ROOT=~/.openclaw/projects/<slug>/code-graph

# Languages to analyze
# CODE_GRAPH_LANGUAGES=py,ts,js,go,rust

# File patterns to include/exclude
# CODE_GRAPH_INCLUDE_PATTERNS=src/**,lib/**
# CODE_GRAPH_EXCLUDE_PATTERNS=test/**,node_modules

# Auto-update code graph on git commit
# CODE_GRAPH_UPDATE_ON_COMMIT=false

# ============================================================================
# Layer 5: Agent Identity & Provenance
# ============================================================================
# Agent identity storage
# AGENT_ID_STORE=~/.openclaw/agent-ids

# Auto-register agent identity on first use
# AGENT_AUTO_REGISTER=true

# Provenance chain storage
# PROVENANCE_ROOT=~/.openclaw/provenance

# Signing key storage (keychain or file)
# PROVENANCE_SIGNING_KEY_STORE=keychain
# PROVENANCE_SIGNING_KEY_FILE=~/.openclaw/.keys/agent.pem

# Hash algorithm for provenance chains
# PROVENANCE_HASH_ALGORITHM=sha256

# Chain verification strictness (strict or lenient)
# PROVENANCE_CHAIN_VERIFICATION=strict

# How long to keep provenance receipts
# PROVENANCE_RECEIPT_TTL_DAYS=365

# Auto-export provenance data
# PROVENANCE_AUTO_EXPORT=false

# ============================================================================
# Policy & Routing
# ============================================================================
# Path to risk-policy.json
# POLICY_CONFIG_PATH=~/.openclaw/extensions/openclaw-lacp-fusion/policy/risk-policy.json

# Default tier for unmatched tasks
# POLICY_DEFAULT_TIER=review

# Approval cache TTL (minutes)
# APPROVAL_CACHE_TTL_MINUTES=30

# Scope approvals per agent+channel
# APPROVAL_CACHE_PER_SCOPE=true

# Cost ceilings per tier (USD)
# COST_CEILING_SAFE_USD=1.00
# COST_CEILING_REVIEW_USD=10.00
# COST_CEILING_CRITICAL_USD=100.00

# Allow agents to request budget override
# BUDGET_OVERRIDE_ALLOWED=true

# ============================================================================
# Hooks System
# ============================================================================
# Enable/disable the hooks system
# HOOKS_ENABLED=true

# Hooks directory (usually auto-configured)
# HOOKS_DIR=~/.openclaw/extensions/openclaw-lacp-fusion/hooks

# Individual hook toggles
# HOOK_SESSION_START_ENABLED=true
# HOOK_PRETOOL_GUARD_ENABLED=true
# HOOK_STOP_QUALITY_GATE_ENABLED=true
# HOOK_WRITE_VALIDATE_ENABLED=true

# Hook execution timeout
# HOOK_TIMEOUT_SECONDS=30

# Hook log level (debug, info, warn, error)
# HOOK_LOG_LEVEL=info

# ============================================================================
# Logging & Monitoring
# ============================================================================
# LOG_LEVEL=info
# LOG_DIR=~/.openclaw/extensions/openclaw-lacp-fusion/logs
# GATED_RUNS_LOG=~/.openclaw/extensions/openclaw-lacp-fusion/logs/gated-runs.jsonl
# MEMORY_LOG=~/.openclaw/extensions/openclaw-lacp-fusion/logs/memory.log
# APPROVAL_LOG=~/.openclaw/extensions/openclaw-lacp-fusion/logs/approvals.jsonl
# PROVENANCE_LOG=~/.openclaw/extensions/openclaw-lacp-fusion/logs/provenance.jsonl
# LOG_RETENTION_DAYS=90
# LOG_COMPRESS_ARCHIVED=true

# ============================================================================
# MCP Integration
# ============================================================================
# MCP_ENABLED=true
# MCP_OBSIDIAN_ENABLED=true
# MCP_SMART_CONNECTIONS_ENABLED=true
# MCP_QMD_ENABLED=true
# MCP_MEMORY_ENABLED=true
# MCP_CONFIG_PATH=~/.openclaw/config/mcp.json

# ============================================================================
# Performance Tuning
# ============================================================================
# CACHE_ENABLED=true
# CACHE_DIR=~/.openclaw/cache
# CACHE_MAX_SIZE_MB=500
# INDEX_REBUILD_INTERVAL_HOURS=24
# PARALLEL_INGEST_WORKERS=4

# ============================================================================
# Feature Flags
# ============================================================================
# All data stays on-device (no external sync)
LACP_LOCAL_FIRST=true

# Enable GitNexus code intelligence
LACP_WITH_GITNEXUS=false

# V2 features
# FEATURE_MEMORY_LAYERS_V2=true
# FEATURE_EVIDENCE_COLLECTION=true
# FEATURE_RELEASE_DISCIPLINE=true
# FEATURE_REMOTE_SANDBOX=false

# ============================================================================
# Per-Machine Customization
# ============================================================================
# Override for machines with external drives or non-standard paths.
# Uncomment and set as needed.
#
# LACP_CUSTOM_MEMORY_ROOT=/Volumes/Cortex/memory
# LACP_CUSTOM_VAULT_ROOT=/Volumes/Cortex/02_engineering
# LACP_CUSTOM_INGEST_DIR=/Volumes/Cortex/06-inbox

# ============================================================================
# Development & Testing
# ============================================================================
# DEBUG_MODE=false
# DRY_RUN_MODE=false
# TEST_MODE=false
# VERBOSE_LOGGING=false
