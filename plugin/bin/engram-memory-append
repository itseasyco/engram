#!/bin/bash

# openclaw-memory-append
# Appends execution results to session memory (cost, gate decisions, exit code, learnings)
# Usage: openclaw-memory-append <session-dir> --cost <usd> --exit-code <code> [--learning <text>] [--gate <decision>]

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default values
COST=0.0
EXIT_CODE=""
LEARNINGS=()
GATES=()

# Usage
usage() {
  cat <<EOF
Usage: openclaw-memory-append <session-dir> [OPTIONS]

Arguments:
  session-dir      Path to session directory (contains memory.md and context.json)

Options:
  --cost <usd>           Cost of execution in USD (e.g., 1.50)
  --exit-code <code>     Exit code (0, 1, 2, etc.)
  --learning <text>      Learning/insight to append (repeatable)
  --gate <decision>      Gate decision to record (repeatable)
  --no-git               Skip git commit

Examples:
  openclaw-memory-append /path/to/session --cost 2.50 --exit-code 0
  openclaw-memory-append /path/to/session --cost 1.0 --exit-code 0 \\
    --learning "Discovered new API pattern" \\
    --learning "Fixed issue with memory cleanup" \\
    --gate "PR review: approved"

Output:
  Updates: context.json with cost, gate decisions, exit code
  Appends: memory.md with learnings and execution summary
  Commits: Changes to git (unless --no-git)
EOF
  exit 1
}

if [[ $# -lt 1 ]]; then
  usage
fi

SESSION_DIR="$1"
shift

# Validate session directory
if [[ ! -d "$SESSION_DIR" ]]; then
  echo -e "${RED}ERROR: Session directory does not exist: $SESSION_DIR${NC}" >&2
  exit 1
fi

if [[ ! -f "$SESSION_DIR/context.json" ]]; then
  echo -e "${RED}ERROR: Missing context.json in $SESSION_DIR${NC}" >&2
  exit 1
fi

# Support both MEMORY.md (created by init) and memory.md
MEMORY_FILE="$SESSION_DIR/MEMORY.md"
if [[ ! -f "$MEMORY_FILE" ]]; then
  MEMORY_FILE="$SESSION_DIR/memory.md"
fi
if [[ ! -f "$MEMORY_FILE" ]]; then
  echo -e "${RED}ERROR: Missing MEMORY.md or memory.md in $SESSION_DIR${NC}" >&2
  exit 1
fi

# Parse options
GIT_COMMIT=true
while [[ $# -gt 0 ]]; do
  case "$1" in
    --cost)
      COST="$2"
      shift 2
      ;;
    --exit-code)
      EXIT_CODE="$2"
      shift 2
      ;;
    --learning)
      LEARNINGS+=("$2")
      shift 2
      ;;
    --gate)
      GATES+=("$2")
      shift 2
      ;;
    --no-git)
      GIT_COMMIT=false
      shift
      ;;
    *)
      echo -e "${RED}ERROR: Unknown option: $1${NC}" >&2
      usage
      ;;
  esac
done

# Validate cost format
if ! [[ "$COST" =~ ^[0-9]+\.[0-9]{2}$ || "$COST" == "0.0" ]]; then
  echo -e "${YELLOW}WARNING: Cost format may be invalid: $COST${NC}" >&2
fi

TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Update context.json with execution results
CONTEXT_FILE="$SESSION_DIR/context.json"

# Build gate_decisions JSON array
GATE_JSON="[]"
if [[ ${#GATES[@]} -gt 0 ]]; then
  GATE_JSON=$(printf '%s\n' "${GATES[@]}" | jq -R . | jq -s .)
fi

# Use jq to safely update context.json
jq \
  --arg cost "$COST" \
  --arg exit_code "$EXIT_CODE" \
  --arg timestamp "$TIMESTAMP" \
  --argjson gates "$GATE_JSON" \
  '.execution.cost_usd = ($cost | tonumber) |
   .execution.exit_code = (if $exit_code == "" then null else ($exit_code | tonumber) end) |
   .execution.gate_decisions = $gates |
   .execution.updated_at = $timestamp' \
  "$CONTEXT_FILE" > "$CONTEXT_FILE.tmp" && \
  mv "$CONTEXT_FILE.tmp" "$CONTEXT_FILE"

echo -e "${GREEN}✓${NC} Updated context.json"

# Append to memory file (MEMORY_FILE resolved earlier to handle MEMORY.md vs memory.md)

# Build execution summary
{
  echo ""
  echo "## Execution Summary — $TIMESTAMP"
  echo ""
  echo "**Cost:** \$${COST}"
  if [[ -n "$EXIT_CODE" ]]; then
    echo "**Exit Code:** ${EXIT_CODE}"
  fi
  echo ""
  
  if [[ ${#GATES[@]} -gt 0 ]]; then
    echo "### Gate Decisions"
    for gate in "${GATES[@]}"; do
      echo "- $gate"
    done
    echo ""
  fi
  
  if [[ ${#LEARNINGS[@]} -gt 0 ]]; then
    echo "### Learnings"
    for learning in "${LEARNINGS[@]}"; do
      echo "- $learning"
    done
    echo ""
  fi
} >> "$MEMORY_FILE"

echo -e "${GREEN}✓${NC} Appended to $(basename "$MEMORY_FILE")"

# Commit to git if enabled
if [[ "$GIT_COMMIT" == "true" ]] && [[ -d "$SESSION_DIR/.git" ]]; then
  cd "$SESSION_DIR"
  
  # Stage changes
  git add "$(basename "$MEMORY_FILE")" context.json
  
  # Create commit message
  COMMIT_MSG="append: execution results — cost=\$${COST}"
  if [[ -n "$EXIT_CODE" ]]; then
    COMMIT_MSG="${COMMIT_MSG} exit_code=${EXIT_CODE}"
  fi
  
  # Commit if there are changes
  if ! git diff --cached --quiet; then
    git commit -q -m "$COMMIT_MSG"
    echo -e "${GREEN}✓${NC} Committed to git"
  else
    echo -e "${YELLOW}~${NC} No changes to commit"
  fi
fi

# Output summary
echo ""
echo -e "${BLUE}Execution Results Recorded${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "Cost:       ${YELLOW}\$${COST}${NC}"
if [[ -n "$EXIT_CODE" ]]; then
  echo -e "Exit Code:  ${YELLOW}${EXIT_CODE}${NC}"
fi
if [[ ${#GATES[@]} -gt 0 ]]; then
  echo -e "Gate Decisions: ${#GATES[@]} recorded"
fi
if [[ ${#LEARNINGS[@]} -gt 0 ]]; then
  echo -e "Learnings:  ${#LEARNINGS[@]} recorded"
fi
echo -e "Location:   ${BLUE}${SESSION_DIR}${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
