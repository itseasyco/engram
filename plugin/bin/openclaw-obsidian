#!/usr/bin/env bash
#
# openclaw-obsidian — Obsidian vault management for OpenClaw LACP
# Status, audit, apply, backup, restore, optimize operations
#

set -euo pipefail

PROG=$(basename "$0")
VERSION="1.0.0"

LACP_OBSIDIAN_VAULT="${LACP_OBSIDIAN_VAULT:-$HOME/obsidian/vault}"
SESSION_MEMORY_ROOT="${SESSION_MEMORY_ROOT:-$HOME/.openclaw/projects}"

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $*" >&2; }
log_success() { echo -e "${GREEN}[✓]${NC} $*" >&2; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $*" >&2; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }

path_to_slug() {
  local path="$1"
  path="${path/#\~/$HOME}"
  path="$(cd "$path" 2>/dev/null && pwd)" || path="$1"
  slug=$(echo "$path" | sed 's|^/||; s|/|-|g; s|-$||')
  echo "$slug"
}

# ============================================================================
# Status: Show vault state
# ============================================================================

vault_status() {
  local vault="$1"

  echo -e "${BLUE}Obsidian Vault Status${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  if [ ! -d "$vault" ]; then
    echo "Status: NOT FOUND"
    echo "Path: $vault"
    echo ""
    echo "Run 'openclaw-brain-graph init' to create the vault."
    return 1
  fi

  echo "Path: $vault"

  # Count files
  local total_files
  total_files=$(find "$vault" -name "*.md" -not -path "*/.obsidian/*" 2>/dev/null | wc -l | tr -d ' ')
  echo "Total notes: $total_files"

  # Count per directory
  local dirs=("00_Index.md" "01_Projects" "02_Concepts" "03_People" "04_Systems" "05_Inbox")
  for dir in "${dirs[@]}"; do
    if [ -d "$vault/$dir" ]; then
      local count
      count=$(find "$vault/$dir" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
      echo "  $dir/: $count notes"
    elif [ -f "$vault/$dir" ]; then
      echo "  $dir: exists"
    fi
  done

  # Vault size
  local vault_size
  vault_size=$(du -sh "$vault" 2>/dev/null | cut -f1)
  echo "Vault size: $vault_size"

  # Last modified
  local last_mod
  last_mod=$(find "$vault" -name "*.md" -not -path "*/.obsidian/*" -exec stat -f '%m %N' {} + 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-)
  if [ -n "$last_mod" ]; then
    echo "Last modified: $(basename "$last_mod")"
  fi

  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

# ============================================================================
# Audit: Check vault integrity
# ============================================================================

vault_audit() {
  local vault="$1"
  local errors=0
  local warnings=0

  echo -e "${BLUE}Vault Audit${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  if [ ! -d "$vault" ]; then
    log_error "Vault not found at $vault"
    return 1
  fi

  # Check structure
  local required_dirs=("01_Projects" "02_Concepts" "05_Inbox")
  for dir in "${required_dirs[@]}"; do
    if [ -d "$vault/$dir" ]; then
      log_success "$dir/ present"
    else
      log_warn "$dir/ missing"
      ((warnings++))
    fi
  done

  # Check for orphan notes (no backlinks)
  local orphan_count=0
  while IFS= read -r file; do
    local basename
    basename=$(basename "$file" .md)
    # Check if any other file links to this note
    local linked
    linked=$(grep -rl "\[\[$basename\]\]" "$vault" --include="*.md" 2>/dev/null | wc -l | tr -d ' ')
    if [ "$linked" -eq 0 ] && [ "$basename" != "00_Index" ] && [ "$basename" != "index" ]; then
      ((orphan_count++))
    fi
  done < <(find "$vault" -name "*.md" -not -path "*/.obsidian/*" -not -path "*/05_Inbox/*" 2>/dev/null)

  if [ "$orphan_count" -gt 0 ]; then
    log_warn "$orphan_count orphan notes (no backlinks)"
    ((warnings++))
  else
    log_success "No orphan notes"
  fi

  # Check for broken links
  local broken_links=0
  while IFS= read -r file; do
    # Extract [[links]] from file
    while IFS= read -r link; do
      [ -z "$link" ] && continue
      if [ ! -f "$vault/$link.md" ] && [ ! -f "$vault/01_Projects/$link.md" ] && [ ! -f "$vault/02_Concepts/$link.md" ]; then
        ((broken_links++))
      fi
    done < <(grep -o '\[\[[^]]*\]\]' "$file" 2>/dev/null | sed 's/\[\[//;s/\]\]//' | head -20)
  done < <(find "$vault" -name "*.md" -not -path "*/.obsidian/*" 2>/dev/null | head -50)

  if [ "$broken_links" -gt 0 ]; then
    log_warn "$broken_links broken links found"
    ((warnings++))
  else
    log_success "No broken links detected"
  fi

  echo ""
  echo "Result: $errors errors, $warnings warnings"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

# ============================================================================
# Apply: Sync project memory to vault
# ============================================================================

vault_apply() {
  local vault="$1"
  local project="$2"

  local slug
  slug=$(path_to_slug "$project")
  local memory_dir="$SESSION_MEMORY_ROOT/$slug/memory"

  echo -e "${BLUE}Applying project memory to vault${NC}"

  if [ ! -d "$vault" ]; then
    log_error "Vault not found. Run 'openclaw-brain-graph init' first."
    return 1
  fi

  if [ ! -d "$memory_dir" ]; then
    log_error "Project memory not found at $memory_dir"
    return 1
  fi

  local project_dir="$vault/01_Projects/$slug"
  mkdir -p "$project_dir"

  # Copy seed files
  local synced=0
  for file in "$memory_dir"/*.md; do
    [ -f "$file" ] || continue
    local basename
    basename=$(basename "$file")
    cp "$file" "$project_dir/$basename"
    ((synced++))
  done

  log_success "Synced $synced files to $project_dir"

  # Update project index
  local index_file="$project_dir/index.md"
  {
    echo "# Project: $slug"
    echo ""
    echo "Auto-synced from session memory on $(date +%Y-%m-%d)."
    echo ""
    echo "## Files"
    echo ""
    for file in "$project_dir"/*.md; do
      [ -f "$file" ] && [ "$(basename "$file")" != "index.md" ] && echo "- [[$(basename "$file" .md)]]"
    done
  } > "$index_file"

  log_success "Updated project index"
}

# ============================================================================
# Backup & Restore
# ============================================================================

vault_backup() {
  local vault="$1"
  local output="${2:-}"

  if [ ! -d "$vault" ]; then
    log_error "Vault not found"
    return 1
  fi

  if [ -z "$output" ]; then
    output="$HOME/.openclaw/backups/vault-$(date +%Y%m%d-%H%M%S).tar.gz"
  fi

  mkdir -p "$(dirname "$output")"

  tar -czf "$output" -C "$(dirname "$vault")" "$(basename "$vault")" 2>/dev/null
  local size
  size=$(du -sh "$output" | cut -f1)

  log_success "Vault backed up to $output ($size)"
  echo "$output"
}

vault_restore() {
  local vault="$1"
  local backup="$2"

  if [ ! -f "$backup" ]; then
    log_error "Backup file not found: $backup"
    return 1
  fi

  log_info "Restoring vault from $backup"

  # Safety: rename existing vault
  if [ -d "$vault" ]; then
    local old_vault="$vault.pre-restore.$(date +%s)"
    mv "$vault" "$old_vault"
    log_info "Existing vault moved to $old_vault"
  fi

  mkdir -p "$(dirname "$vault")"
  tar -xzf "$backup" -C "$(dirname "$vault")" 2>/dev/null

  log_success "Vault restored to $vault"
}

# ============================================================================
# Optimize: Cleanup and compact
# ============================================================================

vault_optimize() {
  local vault="$1"

  echo -e "${BLUE}Optimizing vault${NC}"

  if [ ! -d "$vault" ]; then
    log_error "Vault not found"
    return 1
  fi

  # Remove empty files
  local removed=0
  while IFS= read -r file; do
    local size
    size=$(wc -c < "$file" | tr -d ' ')
    if [ "$size" -eq 0 ]; then
      rm "$file"
      ((removed++))
    fi
  done < <(find "$vault" -name "*.md" -not -path "*/.obsidian/*" 2>/dev/null)

  if [ "$removed" -gt 0 ]; then
    echo "  Removed $removed empty files"
  fi

  # Remove orphaned attachments
  local attachment_dir="$vault/attachments"
  if [ -d "$attachment_dir" ]; then
    local orphan_attachments=0
    while IFS= read -r attachment; do
      local aname
      aname=$(basename "$attachment")
      local referenced
      referenced=$(grep -rl "$aname" "$vault" --include="*.md" 2>/dev/null | wc -l | tr -d ' ')
      if [ "$referenced" -eq 0 ]; then
        ((orphan_attachments++))
      fi
    done < <(find "$attachment_dir" -type f 2>/dev/null)
    echo "  Orphan attachments: $orphan_attachments"
  fi

  # Compact whitespace in all notes
  local compacted=0
  while IFS= read -r file; do
    local original_size
    original_size=$(wc -c < "$file" | tr -d ' ')

    # Collapse 3+ blank lines into 2
    local tmp_file
    tmp_file=$(mktemp)
    awk 'BEGIN{bl=0} /^$/{bl++; if(bl<=2) print; next} {bl=0; print}' "$file" > "$tmp_file"
    mv "$tmp_file" "$file"

    local new_size
    new_size=$(wc -c < "$file" | tr -d ' ')
    if [ "$new_size" -lt "$original_size" ]; then
      ((compacted++))
    fi
  done < <(find "$vault" -name "*.md" -not -path "*/.obsidian/*" 2>/dev/null)

  echo "  Compacted $compacted files"

  log_success "Vault optimized"
}

# ============================================================================
# Main
# ============================================================================

usage() {
  cat <<EOF
$PROG v$VERSION — Obsidian Vault Management

USAGE:
  $PROG <command> [OPTIONS]

COMMANDS:
  status                          Show vault state and statistics
  audit                           Check vault integrity (orphans, broken links)
  apply --project PATH            Sync project memory to vault
  backup [--output FILE]          Create vault backup archive
  restore --from FILE             Restore vault from backup
  optimize                        Cleanup and compact vault
  help                            Show this help

OPTIONS:
  --vault PATH                    Vault path (default: \$LACP_OBSIDIAN_VAULT)

EXAMPLES:
  # Check vault status
  $PROG status

  # Audit vault integrity
  $PROG audit

  # Sync project memory to vault
  $PROG apply --project ~/repos/easy-api

  # Backup vault
  $PROG backup --output ~/backups/vault.tar.gz

  # Restore from backup
  $PROG restore --from ~/backups/vault.tar.gz

  # Optimize vault
  $PROG optimize

EOF
}

main() {
  if [ $# -eq 0 ]; then
    usage
    exit 0
  fi

  local cmd="$1"
  shift

  local vault="$LACP_OBSIDIAN_VAULT"
  local project="."
  local output=""
  local from=""

  # Parse remaining args
  while [ $# -gt 0 ]; do
    case "$1" in
      --vault) vault="$2"; shift 2 ;;
      --project) project="$2"; shift 2 ;;
      --output) output="$2"; shift 2 ;;
      --from) from="$2"; shift 2 ;;
      --help|-h) usage; exit 0 ;;
      *) shift ;;
    esac
  done

  case "$cmd" in
    status) vault_status "$vault" ;;
    audit) vault_audit "$vault" ;;
    apply) vault_apply "$vault" "$project" ;;
    backup) vault_backup "$vault" "$output" ;;
    restore) vault_restore "$vault" "$from" ;;
    optimize) vault_optimize "$vault" ;;
    help|--help|-h) usage ;;
    *) log_error "Unknown command: $cmd"; usage; exit 1 ;;
  esac
}

main "$@"
