#!/usr/bin/env python3
"""
openclaw-brain-ingest: Layer 3 Ingestion Pipeline
Converts transcripts, URLs, PDFs, video/audio, and files into structured indexed notes

Usage:
  openclaw-brain-ingest transcript <vault-path> <file> [--speaker <name>] [--date <date>]
  openclaw-brain-ingest url <vault-path> <url> [--title <title>]
  openclaw-brain-ingest pdf <vault-path> <file> [--title <title>]
  openclaw-brain-ingest file <vault-path> <file> [--title <title>]
  openclaw-brain-ingest video <vault-path> <file> [--title <title>] [--speaker <name>] [--model <whisper-model>]
  openclaw-brain-ingest index <vault-path> [--qmd]
"""

import sys
import json
import argparse
import subprocess
import tempfile
import shutil
from pathlib import Path
from datetime import datetime
import hashlib

import re

MEDIA_EXTENSIONS = {
    ".mp4", ".m4v", ".mov", ".mkv", ".avi", ".webm",
    ".mp3", ".wav", ".aac", ".ogg", ".opus", ".flac", ".m4a",
}


def _slugify(text):
    """Convert text to a clean prose-style filename slug.

    Prose-style: 'payment-settlement-architecture' not 'file_c892a314'
    Good for Obsidian graph readability and wikilinks.
    """
    text = text.strip()
    # Remove common prefixes/noise
    text = re.sub(r'^(transcript|file|url|pdf|video)\s*[—–-]\s*', '', text, flags=re.IGNORECASE)
    text = text.lower()
    text = re.sub(r'[^\w\s-]', '', text)
    text = re.sub(r'[\s_]+', '-', text)
    text = re.sub(r'-+', '-', text).strip('-')
    return text[:80] or "untitled"


def _prose_title(filename):
    """Generate a human-readable prose title from a filename.

    'payment-checkout-flow.md' -> 'Payment Checkout Flow'
    '2026-03-24-meeting-notes.txt' -> 'Meeting Notes (2026-03-24)'
    """
    stem = Path(filename).stem
    # Extract date if present
    date_match = re.match(r'^(\d{4}-\d{2}-\d{2})[_-]?(.*)', stem)
    if date_match:
        date_str = date_match.group(1)
        rest = date_match.group(2).replace("-", " ").replace("_", " ").strip()
        title = rest.title() if rest else "Notes"
        return f"{title} ({date_str})"
    # Clean up the stem
    title = stem.replace("-", " ").replace("_", " ").strip().title()
    return title or "Untitled"


def _extract_tags(content, title=""):
    """Extract relevant tags from content using keyword detection."""
    tags = set()
    combined = (title + " " + content).lower()

    tag_keywords = {
        "payment": ["payment", "finix", "brale", "settlement", "payout", "checkout"],
        "api": ["api", "endpoint", "route", "rest", "graphql"],
        "auth": ["auth", "login", "session", "token", "oauth", "passkey"],
        "database": ["database", "migration", "rls", "supabase", "postgres", "schema"],
        "architecture": ["architecture", "design", "system", "infrastructure"],
        "meeting": ["meeting", "discussed", "agenda", "action items", "attendees"],
        "security": ["security", "vulnerability", "audit", "encryption"],
        "testing": ["test", "jest", "pytest", "coverage", "e2e", "maestro"],
        "deployment": ["deploy", "ci/cd", "vercel", "render", "github actions"],
        "frontend": ["react", "next.js", "tailwind", "component", "dashboard"],
        "mobile": ["mobile", "ios", "android", "react native", "expo"],
        "sdk": ["sdk", "client library", "integration"],
    }

    for tag, keywords in tag_keywords.items():
        if any(kw in combined for kw in keywords):
            tags.add(tag)

    return sorted(tags) if tags else ["general"]


def _detect_category(content, title="", source_type="file"):
    """Detect the best vault category for this content."""
    combined = (title + " " + content).lower()

    if source_type == "transcript" or any(w in combined for w in ["meeting", "discussed", "agenda", "attendees", "speaker:"]):
        return "sessions"
    if any(w in combined for w in ["architecture", "system design", "infrastructure", "deployment"]):
        return "engineering"
    if any(w in combined for w in ["research", "analysis", "comparison", "evaluation"]):
        return "reference"
    if any(w in combined for w in ["roadmap", "feature", "prd", "requirement", "milestone"]):
        return "projects"
    if any(w in combined for w in ["strategy", "investor", "fundrais", "partnership", "revenue"]):
        return "strategy"
    return "inbox"


def _build_frontmatter(title, category, tags, source_type, source_name=""):
    """Generate YAML frontmatter."""
    now = datetime.now().strftime("%Y-%m-%d")
    tag_str = ", ".join(tags)
    return f"""---
title: "{title}"
category: {category}
tags: [{tag_str}]
created: {now}
updated: {now}
author: engram-ingest
source: {source_type}
source_file: {source_name}
status: active
---"""


def _resolve_inbox(vault_path):
    """Resolve the inbox path, respecting mode."""
    vault = Path(vault_path)
    inbox = vault / "inbox" / "queue-generated"
    inbox.mkdir(parents=True, exist_ok=True)
    if _INGEST_MODE_STATUS == "redirected_to_inbox":
        from mode import get_inbox_queue_path
        inbox = Path(get_inbox_queue_path())
        inbox.mkdir(parents=True, exist_ok=True)
    return inbox

from pathlib import Path as _Path
import sys as _sys
_sys.path.insert(0, str(_Path(__file__).resolve().parent / "lib"))
from mode_check import guard_or_exit

_INGEST_MODE_STATUS = guard_or_exit("brain-ingest", json_output="--json" in _sys.argv)


def ingest_transcript(vault_path, transcript_file, speaker=None, date=None):
    """Ingest a transcript file"""
    inbox = _resolve_inbox(vault_path)
    content = Path(transcript_file).read_text() if Path(transcript_file).exists() else ""

    title = f"Transcript — {speaker or 'Unknown'} ({date or datetime.now().strftime('%Y-%m-%d')})"
    slug = _slugify(title)
    tags = _extract_tags(content, title)
    tags.append("transcript")
    category = "sessions"
    frontmatter = _build_frontmatter(title, category, tags, "transcript", Path(transcript_file).name)

    note = f"""{frontmatter}

# {title}

**Speaker:** {speaker or 'Unknown'}
**Date:** {date or datetime.now().strftime('%Y-%m-%d')}

## Content

{content}
"""

    output_file = inbox / f"{slug}.md"
    output_file.write_text(note)
    print(f"Ingested: {output_file}")
    return str(output_file)


def _fetch_url(url, timeout=30):
    """Fetch text content from a URL. Returns the body text or an error string."""
    import urllib.request
    import urllib.error
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "engram-brain-ingest/1.0"})
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
    except (urllib.error.URLError, urllib.error.HTTPError, OSError) as exc:
        return f"(Failed to fetch URL: {exc})"

    # Strip HTML tags if the response looks like HTML
    if "<html" in raw[:1000].lower() or "<head" in raw[:1000].lower():
        # Simple tag stripping — good enough for ingestion notes
        clean = re.sub(r"<script[^>]*>.*?</script>", "", raw, flags=re.DOTALL | re.IGNORECASE)
        clean = re.sub(r"<style[^>]*>.*?</style>", "", clean, flags=re.DOTALL | re.IGNORECASE)
        clean = re.sub(r"<[^>]+>", " ", clean)
        clean = re.sub(r"\s{2,}", "\n", clean).strip()
        return clean[:10000]  # cap at 10k chars for vault notes
    return raw[:10000]


def ingest_url(vault_path, url, title=None):
    """Ingest content from a URL"""
    inbox = _resolve_inbox(vault_path)
    title = title or url.split("//")[-1].split("/")[0]
    slug = _slugify(title)

    # Fetch the actual content
    content = _fetch_url(url)

    tags = _extract_tags(content + " " + url, title)
    tags.append("url")
    category = _detect_category(title + " " + url + " " + content[:500], title, "url")
    frontmatter = _build_frontmatter(title, category, tags, "url", url)

    note = f"""{frontmatter}

# {title}

**Source:** [{url}]({url})

## Content

{content}
"""

    output_file = inbox / f"{slug}.md"
    output_file.write_text(note)
    print(f"Ingested: {output_file}")
    return str(output_file)


def _extract_pdf_text(pdf_path):
    """Extract text from a PDF. Tries pdftotext (poppler) first, falls back to Python."""
    pdf_path = str(pdf_path)

    # Try pdftotext (poppler-utils) — best quality
    if shutil.which("pdftotext"):
        try:
            result = subprocess.run(
                ["pdftotext", "-layout", pdf_path, "-"],
                capture_output=True, text=True, timeout=60
            )
            if result.returncode == 0 and result.stdout.strip():
                return result.stdout.strip()[:20000]
        except (subprocess.TimeoutExpired, OSError):
            pass

    # Fallback: read raw bytes and extract text-like content
    try:
        raw = Path(pdf_path).read_bytes()
        # Extract strings between parentheses (PDF text objects) and between BT/ET blocks
        import codecs
        text_parts = []
        for match in re.finditer(rb'\(([^)]{2,})\)', raw):
            try:
                decoded = match.group(1).decode('utf-8', errors='ignore')
                if any(c.isalpha() for c in decoded):
                    text_parts.append(decoded)
            except Exception:
                continue
        if text_parts:
            return "\n".join(text_parts)[:20000]
    except Exception:
        pass

    return "(PDF text extraction failed — install poppler-utils: brew install poppler)"


def ingest_pdf(vault_path, pdf_file, title=None):
    """Ingest a PDF file"""
    inbox = _resolve_inbox(vault_path)
    pdf_path = Path(pdf_file)
    title = title or _prose_title(pdf_path.name)
    slug = _slugify(title)

    # Extract actual text from the PDF
    content = _extract_pdf_text(pdf_path)

    tags = _extract_tags(content[:2000] + " " + title, title)
    tags.append("pdf")
    category = _detect_category(content[:2000] + " " + title, title, "pdf")
    frontmatter = _build_frontmatter(title, category, tags, "pdf", pdf_path.name)

    note = f"""{frontmatter}

# {title}

**Source file:** `{pdf_path.name}`

## Content

{content}
"""

    output_file = inbox / f"{slug}.md"
    output_file.write_text(note)
    print(f"Ingested: {output_file}")
    return str(output_file)


def ingest_file(vault_path, file_path, title=None):
    """Ingest a generic file"""
    inbox = _resolve_inbox(vault_path)
    file_obj = Path(file_path)
    content = file_obj.read_text(errors='ignore') if file_obj.exists() else ""

    title = title or _prose_title(file_obj.name)
    slug = _slugify(title)
    tags = _extract_tags(content, title)
    category = _detect_category(content, title, "file")
    frontmatter = _build_frontmatter(title, category, tags, "file", file_obj.name)

    note = f"""{frontmatter}

# {title}

{content}
"""

    output_file = inbox / f"{slug}.md"
    # Handle collision
    if output_file.exists():
        slug = slug + "-" + hashlib.md5(file_path.encode()).hexdigest()[:6]
        output_file = inbox / f"{slug}.md"

    output_file.write_text(note)
    print(f"Ingested: {output_file}")
    return str(output_file)


def _extract_audio(video_path, output_path):
    """Extract audio from video using ffmpeg."""
    if not shutil.which("ffmpeg"):
        raise FileNotFoundError("ffmpeg is required for video ingestion. Install: brew install ffmpeg")
    cmd = [
        "ffmpeg", "-i", str(video_path),
        "-vn", "-acodec", "pcm_s16le", "-ar", "16000", "-ac", "1",
        str(output_path), "-y", "-loglevel", "error",
    ]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        raise RuntimeError(f"ffmpeg failed: {result.stderr.strip()}")


def _transcribe_audio(audio_path, model="base"):
    """Transcribe audio using insanely-fast-whisper (GPU-accelerated) or openai-whisper fallback.

    Tries in order:
      1. insanely-fast-whisper (installed via pipx)
      2. pipx run insanely-fast-whisper (no install needed)
      3. openai-whisper CLI (legacy fallback)
    """
    import platform as _platform

    model_id = {
        "tiny": "openai/whisper-tiny",
        "base": "openai/whisper-base",
        "small": "openai/whisper-small",
        "medium": "openai/whisper-medium",
        "large": "openai/whisper-large-v3",
    }.get(model, f"openai/whisper-{model}")

    # macOS needs --device-id mps and lower batch size to avoid OOM
    is_mac = _platform.system() == "Darwin"
    extra_args = []
    if is_mac:
        extra_args += ["--device-id", "mps", "--batch-size", "4"]

    def _run_ifw(cmd_prefix):
        """Run insanely-fast-whisper with given command prefix, return transcript text."""
        with tempfile.NamedTemporaryFile(suffix=".json", delete=False) as tmp:
            output_path = tmp.name

        cmd = cmd_prefix + [
            "--file-name", str(audio_path),
            "--model-name", model_id,
            "--transcript-path", output_path,
        ] + extra_args

        label = cmd_prefix[0] if cmd_prefix[0] != "pipx" else "pipx run"
        print(f"Transcribing with {label} insanely-fast-whisper ({model} model)...")
        if is_mac:
            print(f"  (macOS: using MPS device, batch-size 4)")

        result = subprocess.run(cmd, capture_output=True, text=True, timeout=3600)
        if result.returncode != 0:
            stderr = result.stderr.strip()
            if stderr:
                print(f"  stderr: {stderr}", file=sys.stderr)
            Path(output_path).unlink(missing_ok=True)
            return None

        try:
            import json as _json
            data = _json.loads(Path(output_path).read_text())
            text = data.get("text", "")
            if not text and "chunks" in data:
                text = " ".join(c.get("text", "") for c in data["chunks"])
            return text.strip() or None
        except Exception:
            return None
        finally:
            Path(output_path).unlink(missing_ok=True)

    # 1. Installed insanely-fast-whisper
    if shutil.which("insanely-fast-whisper"):
        result = _run_ifw(["insanely-fast-whisper"])
        if result:
            return result

    # 2. pipx run (no install needed, temporary environment)
    if shutil.which("pipx"):
        result = _run_ifw(["pipx", "run", "insanely-fast-whisper"])
        if result:
            return result

    # 3. Legacy openai-whisper CLI
    if shutil.which("whisper"):
        with tempfile.TemporaryDirectory() as tmpdir:
            cmd = [
                "whisper", str(audio_path),
                "--model", model,
                "--output_format", "txt",
                "--output_dir", tmpdir,
                "--language", "en",
            ]
            print(f"Transcribing with whisper ({model} model)...")
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=3600)
            if result.returncode != 0:
                stderr = result.stderr.strip()
                if stderr:
                    print(f"whisper stderr: {stderr}", file=sys.stderr)

            txt_files = list(Path(tmpdir).glob("*.txt"))
            if not txt_files:
                raise RuntimeError("whisper produced no output")

            return txt_files[0].read_text(encoding="utf-8").strip()

    raise FileNotFoundError(
        "No transcription tool found.\n"
        "  Install: brew install pipx && pipx install insanely-fast-whisper==0.0.15\n"
        "  Or run without installing: pipx run insanely-fast-whisper --file-name <file>"
    )


def _get_video_duration(video_path):
    """Get video duration in seconds using ffprobe."""
    if not shutil.which("ffprobe"):
        return None
    try:
        result = subprocess.run(
            ["ffprobe", "-v", "error", "-show_entries", "format=duration",
             "-of", "default=noprint_wrappers=1:nokey=1", str(video_path)],
            capture_output=True, text=True, timeout=10,
        )
        return float(result.stdout.strip()) if result.returncode == 0 else None
    except (ValueError, subprocess.TimeoutExpired):
        return None


def ingest_video(vault_path, video_file, title=None, speaker=None, model="base"):
    """Ingest a video or audio file by extracting audio, transcribing, and creating a vault note."""
    vault = Path(vault_path)
    inbox = vault / "inbox" / "queue-generated"
    inbox.mkdir(parents=True, exist_ok=True)

    if _INGEST_MODE_STATUS == "redirected_to_inbox":
        from mode import get_inbox_queue_path
        inbox = Path(get_inbox_queue_path())
        inbox.mkdir(parents=True, exist_ok=True)

    video = Path(video_file)
    if not video.exists():
        print(f"Error: file not found: {video_file}", file=sys.stderr)
        sys.exit(1)

    suffix = video.suffix.lower()
    if suffix not in MEDIA_EXTENSIONS:
        print(f"Error: unsupported format {suffix}. Supported: {', '.join(sorted(MEDIA_EXTENSIONS))}", file=sys.stderr)
        sys.exit(1)

    title = title or video.stem.replace("_", " ").replace("-", " ").title()
    date_str = datetime.now().strftime("%Y-%m-%d")
    duration = _get_video_duration(video)
    duration_str = f"{int(duration // 60)}m {int(duration % 60)}s" if duration else "unknown"

    # Audio-only files skip ffmpeg extraction
    audio_extensions = {".mp3", ".wav", ".aac", ".ogg", ".opus", ".flac", ".m4a"}
    is_audio_only = suffix in audio_extensions

    with tempfile.TemporaryDirectory() as tmpdir:
        if is_audio_only:
            audio_path = video
            print(f"Audio file detected: {video.name}")
        else:
            audio_path = Path(tmpdir) / "audio.wav"
            print(f"Extracting audio from {video.name}...")
            _extract_audio(video, audio_path)

        transcript = _transcribe_audio(str(audio_path), model=model)

    if not transcript:
        print("Error: transcription produced no text", file=sys.stderr)
        sys.exit(1)

    word_count = len(transcript.split())
    slug = "video_" + hashlib.md5(video_file.encode()).hexdigest()[:8]

    note = f"""---
title: "{title}"
category: transcript
tags: [meeting, video, transcript]
created: {date_str}
updated: {date_str}
author: engram-ingest
source: video-transcription
status: active
---

# {title}

## Metadata
- **Type:** Video Transcript
- **Source file:** `{video.name}`
- **Speaker:** {speaker or 'Unknown'}
- **Duration:** {duration_str}
- **Words:** {word_count}
- **Whisper model:** {model}
- **Ingested:** {datetime.now().isoformat()}

## Transcript

{transcript}

---
Ingested by engram-brain-ingest (video)
"""

    output_file = inbox / f"{slug}.md"
    output_file.write_text(note)
    print(f"Ingested: {output_file} ({word_count} words, {duration_str})")
    return str(output_file)


def ingest_video_batch(vault_path, directory, title_prefix=None, speaker=None, model="base"):
    """Ingest all video/audio files in a directory."""
    dir_path = Path(directory)
    if not dir_path.is_dir():
        print(f"Error: not a directory: {directory}", file=sys.stderr)
        sys.exit(1)

    media_files = sorted(
        f for f in dir_path.iterdir()
        if f.suffix.lower() in MEDIA_EXTENSIONS and f.is_file()
    )

    if not media_files:
        print(f"No media files found in {directory}")
        return []

    print(f"Found {len(media_files)} media files in {directory}")
    results = []

    for i, media_file in enumerate(media_files, 1):
        title = f"{title_prefix} - {media_file.stem}" if title_prefix else None
        print(f"\n[{i}/{len(media_files)}] Processing: {media_file.name}")
        try:
            result = ingest_video(vault_path, str(media_file), title=title, speaker=speaker, model=model)
            results.append(result)
        except Exception as e:
            print(f"  Error: {e}", file=sys.stderr)
            continue

    print(f"\nBatch complete: {len(results)}/{len(media_files)} ingested")
    return results


def index_vault(vault_path, update_qmd=False):
    """Rebuild vault index"""
    vault = Path(vault_path)
    inbox = vault / "inbox" / "queue-generated"
    
    # Find all .md files
    files = list(inbox.glob("*.md"))
    
    # Build index
    index_content = "# Ingested Notes Index\n\nAuto-generated.\n\n"
    for f in sorted(files):
        if f.name != "index.md":
            index_content += f"- [{f.stem}]({f.name})\n"
    
    (inbox / "index.md").write_text(index_content)
    print(f"Indexed: {inbox / 'index.md'}")
    
    if update_qmd:
        print("Note: QMD update would run here")


def main():
    parser = argparse.ArgumentParser(description="Ingest content into knowledge graph")
    subparsers = parser.add_subparsers(dest="command", required=True)
    
    # Transcript
    trans_parser = subparsers.add_parser("transcript")
    trans_parser.add_argument("vault_path")
    trans_parser.add_argument("transcript_file")
    trans_parser.add_argument("--speaker")
    trans_parser.add_argument("--date")
    
    # URL
    url_parser = subparsers.add_parser("url")
    url_parser.add_argument("vault_path")
    url_parser.add_argument("url")
    url_parser.add_argument("--title")
    
    # PDF
    pdf_parser = subparsers.add_parser("pdf")
    pdf_parser.add_argument("vault_path")
    pdf_parser.add_argument("pdf_file")
    pdf_parser.add_argument("--title")
    
    # File
    file_parser = subparsers.add_parser("file")
    file_parser.add_argument("vault_path")
    file_parser.add_argument("file_path")
    file_parser.add_argument("--title")
    
    # Video (single file)
    video_parser = subparsers.add_parser("video", help="Transcribe and ingest a video/audio file")
    video_parser.add_argument("vault_path")
    video_parser.add_argument("video_file")
    video_parser.add_argument("--title")
    video_parser.add_argument("--speaker")
    video_parser.add_argument("--model", default="base", help="Whisper model: tiny, base, small, medium, large (default: base)")

    # Video batch (whole directory)
    batch_parser = subparsers.add_parser("video-batch", help="Transcribe and ingest all media in a directory")
    batch_parser.add_argument("vault_path")
    batch_parser.add_argument("directory")
    batch_parser.add_argument("--title-prefix", help="Prefix for generated titles")
    batch_parser.add_argument("--speaker")
    batch_parser.add_argument("--model", default="base", help="Whisper model: tiny, base, small, medium, large (default: base)")

    # Index
    index_parser = subparsers.add_parser("index")
    index_parser.add_argument("vault_path")
    index_parser.add_argument("--qmd", action="store_true")

    args = parser.parse_args()

    if args.command == "transcript":
        ingest_transcript(args.vault_path, args.transcript_file, args.speaker, args.date)
    elif args.command == "url":
        ingest_url(args.vault_path, args.url, args.title)
    elif args.command == "pdf":
        ingest_pdf(args.vault_path, args.pdf_file, args.title)
    elif args.command == "file":
        ingest_file(args.vault_path, args.file_path, args.title)
    elif args.command == "video":
        ingest_video(args.vault_path, args.video_file, args.title, args.speaker, args.model)
    elif args.command == "video-batch":
        ingest_video_batch(args.vault_path, args.directory, args.title_prefix, args.speaker, args.model)
    elif args.command == "index":
        index_vault(args.vault_path, args.qmd)


if __name__ == "__main__":
    main()
