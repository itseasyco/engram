#!/usr/bin/env python3
"""
engram-code-report — Comprehensive code health report using GitNexus knowledge graph.

Runs multiple analysis queries against indexed repos and produces a structured
report: strengths, improvement areas, and issues.

Usage:
  engram code report [--repo <name>] [--all] [--json] [--output <path>]
  engram code dead-code [--repo <name>]
  engram code hotspots [--repo <name>]
  engram code blast-radius [--repo <name>]
  engram code orphans [--repo <name>]
  engram code architecture [--repo <name>]
"""

import argparse
import json
import os
import subprocess
import sys
from datetime import datetime


# ── Colors ──────────────────────────────────────────────────────────────────
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
RED = "\033[0;31m"
CYAN = "\033[0;36m"
BOLD = "\033[1m"
DIM = "\033[2m"
NC = "\033[0m"


def strip_ansi(text: str) -> str:
    """Remove ANSI escape codes from text."""
    import re
    return re.sub(r'\033\[[0-9;]*m', '', text)


class Output:
    """Handles writing to both stdout and optional file."""

    def __init__(self, file_path: str | None = None):
        self.file_path = file_path
        self._lines: list[str] = []

    def print(self, *args, **kwargs):
        import io
        buf = io.StringIO()
        print(*args, file=buf, **kwargs)
        text = buf.getvalue()
        sys.stdout.write(text)
        if self.file_path:
            self._lines.append(strip_ansi(text))

    def save(self):
        if self.file_path and self._lines:
            os.makedirs(os.path.dirname(os.path.abspath(self.file_path)), exist_ok=True)
            with open(self.file_path, "w") as f:
                f.writelines(self._lines)
            print(f"\n{GREEN}Report saved to: {self.file_path}{NC}")


# Global output handler
out = Output()


def banner():
    out.print(f"""
{BOLD}{CYAN}  ███████╗███╗   ██╗ ██████╗ ██████╗  █████╗ ███╗   ███╗
  ██╔════╝████╗  ██║██╔════╝ ██╔══██╗██╔══██╗████╗ ████║
  █████╗  ██╔██╗ ██║██║  ███╗██████╔╝███████║██╔████╔██║
  ██╔══╝  ██║╚██╗██║██║   ██║██╔══██╗██╔══██║██║╚██╔╝██║
  ███████╗██║ ╚████║╚██████╔╝██║  ██║██║  ██║██║ ╚═╝ ██║
  ╚══════╝╚═╝  ╚═══╝ ╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═╝╚═╝     ╚═╝{NC}
{BOLD}{YELLOW}   ██████╗ ██████╗ ██████╗ ███████╗
  ██╔════╝██╔═══██╗██╔══██╗██╔════╝
  ██║     ██║   ██║██║  ██║█████╗
  ██║     ██║   ██║██║  ██║██╔══╝
