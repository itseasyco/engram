   ╚═════╝ ╚═════╝ ╚═════╝ ╚══════╝
  ██████╗ ███████╗██████╗  ██████╗ ██████╗ ████████╗
  ██╔══██╗██╔════╝██╔══██╗██╔═══██╗██╔══██╗╚══██╔══╝
  ██████╔╝█████╗  ██████╔╝██║   ██║██████╔╝   ██║
  ██╔══██╗██╔══╝  ██╔═══╝ ██║   ██║██╔══██╗   ██║
  ██║  ██║███████╗██║     ╚██████╔╝██║  ██║   ██║
  ╚═╝  ╚═╝╚══════╝╚═╝      ╚═════╝ ╚═╝  ╚═╝   ╚═╝{NC}
""")


# ── GitNexus Query Runner ────────────────────────────────────────────────────

def run_cypher(repo: str, query: str) -> dict | None:
    """Run a cypher query via gitnexus CLI and return parsed result."""
    try:
        result = subprocess.run(
            ["npx", "gitnexus", "cypher", "--repo", repo, query],
            capture_output=True, text=True, timeout=30
        )
        if result.returncode != 0:
            return None
        data = json.loads(result.stdout)
        if "error" in data:
            return None
        return data
    except (subprocess.TimeoutExpired, json.JSONDecodeError, FileNotFoundError):
        return None


def parse_markdown_table(markdown: str) -> list[dict]:
    """Parse a GitNexus markdown table into list of dicts."""
    lines = [l.strip() for l in markdown.strip().split("\n") if l.strip()]
    if len(lines) < 3:
        return []
    headers = [h.strip() for h in lines[0].split("|") if h.strip()]
    rows = []
    for line in lines[2:]:  # skip header + separator
        cells = [c.strip() for c in line.split("|") if c.strip()]
        if len(cells) == len(headers):
            rows.append(dict(zip(headers, cells)))
    return rows


def query(repo: str, cypher: str) -> list[dict]:
    """Run cypher query and return rows as list of dicts."""
    result = run_cypher(repo, cypher)
    if not result or "markdown" not in result:
        return []
    return parse_markdown_table(result["markdown"])


def get_indexed_repos() -> list[str]:
    """Get list of indexed repo names."""
    try:
        result = subprocess.run(
            ["npx", "gitnexus", "list", "--json"],
            capture_output=True, text=True, timeout=15
        )
        if result.returncode == 0:
            data = json.loads(result.stdout)
            if isinstance(data, list):
                return [r.get("name", "") for r in data if r.get("name")]
    except (subprocess.TimeoutExpired, json.JSONDecodeError, FileNotFoundError):
        pass
    # Fallback: parse text output
    try:
        result = subprocess.run(
            ["npx", "gitnexus", "list"],
            capture_output=True, text=True, timeout=15
        )
        repos = []
        for line in result.stdout.split("\n"):
            line = line.strip()
            if line and not line.startswith(("Indexed", "Path:", "Commit:", "Stats:", "Clusters:", "Processes:")):
                if not line.startswith(("─", "=")) and "/" not in line and ":" not in line:
                    repos.append(line)
        return repos
    except:
        return []


# ── Analysis Queries ──────────────────────────────────────────────────────────

def get_overview(repo: str) -> dict:
    """Get basic stats about the repo."""
    rows = query(repo, """
        MATCH (n)
        RETURN label(n) AS node_type, count(*) AS cnt
        ORDER BY cnt DESC
    """)
    rels = query(repo, """
        MATCH ()-[r:CodeRelation]->()
        RETURN r.type AS rel_type, count(*) AS cnt
        ORDER BY cnt DESC
    """)
    return {"nodes": rows, "relationships": rels}


def get_dead_exports(repo: str, limit: int = 30) -> list[dict]:
    """Find exported functions that nothing calls."""
    return query(repo, f"""
        MATCH (f:Function)
        WHERE f.isExported = true
          AND NOT ()-[:CodeRelation {{type: "CALLS"}}]->(f)
        RETURN f.name AS name, f.filePath AS file, f.startLine AS line
        ORDER BY f.filePath
        LIMIT {limit}
    """)


def get_complexity_hotspots(repo: str, threshold: int = 10, limit: int = 20) -> list[dict]:
    """Find files with too many functions."""
    return query(repo, f"""
        MATCH (f:Function)
        WITH f.filePath AS file, count(*) AS fn_count
        WHERE fn_count >= {threshold}
        RETURN file, fn_count
        ORDER BY fn_count DESC
        LIMIT {limit}
    """)


def get_blast_radius(repo: str, threshold: int = 5, limit: int = 20) -> list[dict]:
    """Find functions with the most callers (highest risk)."""
    return query(repo, f"""
        MATCH (caller)-[:CodeRelation {{type: "CALLS"}}]->(f:Function)
        WITH f.name AS name, f.filePath AS file, count(caller) AS callers
        WHERE callers >= {threshold}
        RETURN name, file, callers
        ORDER BY callers DESC
        LIMIT {limit}
    """)


def get_orphan_files(repo: str, limit: int = 30) -> list[dict]:
    """Find source files that nothing imports."""
    return query(repo, f"""
        MATCH (f:File)
        WHERE NOT ()-[:CodeRelation {{type: "IMPORTS"}}]->(f)
          AND f.filePath CONTAINS "src/"
          AND NOT f.filePath CONTAINS "test"
          AND NOT f.filePath CONTAINS "migrations"
          AND NOT f.filePath CONTAINS "scripts"
          AND NOT f.filePath CONTAINS "__"
        RETURN f.filePath AS file
        ORDER BY f.filePath
        LIMIT {limit}
    """)


def get_architecture_clusters(repo: str) -> list[dict]:
    """Get functional clusters and their cohesion."""
    return query(repo, """
        MATCH (c:Community)
        WHERE c.symbolCount > 5
        RETURN c.label AS cluster, c.symbolCount AS symbols, c.cohesion AS cohesion
        ORDER BY c.symbolCount DESC
        LIMIT 20
    """)


def get_cross_cluster_calls(repo: str, limit: int = 15) -> list[dict]:
    """Find functions that call across clusters (coupling indicators)."""
    return query(repo, f"""
        MATCH (p:Process)
        WHERE p.processType = "cross_community"
          AND p.stepCount > 3
        RETURN p.label AS process, p.stepCount AS steps
        ORDER BY p.stepCount DESC
        LIMIT {limit}
    """)


def get_well_structured_files(repo: str, limit: int = 10) -> list[dict]:
    """Find files with good function counts (3-8 functions, well-modularized)."""
    return query(repo, f"""
        MATCH (f:Function)
        WITH f.filePath AS file, count(*) AS fn_count
        WHERE fn_count >= 3 AND fn_count <= 8
        RETURN file, fn_count
        ORDER BY fn_count DESC
        LIMIT {limit}
    """)


def get_well_connected_functions(repo: str, limit: int = 10) -> list[dict]:
    """Find functions that are both called by others AND call others (good middleware)."""
    return query(repo, f"""
        MATCH (caller)-[:CodeRelation {{type: "CALLS"}}]->(f:Function)-[:CodeRelation {{type: "CALLS"}}]->(callee)
        WITH f.name AS name, f.filePath AS file,
             count(DISTINCT caller) AS incoming, count(DISTINCT callee) AS outgoing
        WHERE incoming >= 2 AND outgoing >= 2
        RETURN name, file, incoming, outgoing
        ORDER BY incoming + outgoing DESC
        LIMIT {limit}
    """)


def get_process_coverage(repo: str) -> dict:
    """How many processes are mapped and their types."""
    rows = query(repo, """
        MATCH (p:Process)
        RETURN p.processType AS process_type, count(*) AS cnt
        ORDER BY cnt DESC
    """)
    total = query(repo, "MATCH (p:Process) RETURN count(p) AS total")
    return {
        "types": rows,
        "total": int(total[0]["total"]) if total else 0
    }


# ── Report Formatting ─────────────────────────────────────────────────────────

def section(title: str, color: str = BOLD):
    out.print(f"\n{color}{'─' * 60}{NC}")
    out.print(f"{color}  {title}{NC}")
    out.print(f"{color}{'─' * 60}{NC}\n")


def print_table(rows: list[dict], max_col_width: int = 60):
    """Print rows as a formatted table."""
    if not rows:
        out.print(f"  {DIM}No results{NC}")
        return
    headers = list(rows[0].keys())
    # Compute column widths
    widths = {h: min(max(len(h), max(len(str(r.get(h, ""))[:max_col_width]) for r in rows)), max_col_width) for h in headers}
    # Header
    header_line = "  " + "  ".join(f"{h:<{widths[h]}}" for h in headers)
    out.print(f"{DIM}{header_line}{NC}")
    out.print(f"  {DIM}{'  '.join('─' * widths[h] for h in headers)}{NC}")
    # Rows
    for row in rows:
        cells = []
        for h in headers:
            val = str(row.get(h, ""))[:max_col_width]
            cells.append(f"{val:<{widths[h]}}")
        out.print(f"  {'  '.join(cells)}")


def run_single_report(repo: str, report_type: str):
    """Run a single focused report."""
    out.print(f"\n{BOLD}{repo}{NC} — {report_type}\n")

    if report_type == "dead-code":
        rows = get_dead_exports(repo, limit=50)
        out.print(f"  Exported functions with no callers: {BOLD}{len(rows)}{NC}")
        out.print(f"  {DIM}(Route handlers registered at runtime may appear here){NC}\n")
        print_table(rows)

    elif report_type == "hotspots":
        rows = get_complexity_hotspots(repo, threshold=8)
        out.print(f"  Files with 8+ functions: {BOLD}{len(rows)}{NC}\n")
        print_table(rows)

    elif report_type == "blast-radius":
        rows = get_blast_radius(repo, threshold=3)
        out.print(f"  Functions with 3+ callers: {BOLD}{len(rows)}{NC}")
        out.print(f"  {DIM}(Higher = riskier to change){NC}\n")
        print_table(rows)

    elif report_type == "orphans":
        rows = get_orphan_files(repo)
        out.print(f"  Source files nothing imports: {BOLD}{len(rows)}{NC}")
        out.print(f"  {DIM}(Framework auto-loaders may register these at runtime){NC}\n")
        print_table(rows)

    elif report_type == "architecture":
        clusters = get_architecture_clusters(repo)
        cross = get_cross_cluster_calls(repo)
        out.print(f"  Functional clusters (>5 symbols):\n")
        print_table(clusters)
        if cross:
            out.print(f"\n  Cross-cluster processes (coupling indicators):\n")
            print_table(cross)

    else:
        out.print(f"  {RED}Unknown report type: {report_type}{NC}")
        out.print(f"  Available: dead-code, hotspots, blast-radius, orphans, architecture")


def run_full_report(repo: str, output_json: bool = False):
    """Run the complete code health report for a repo."""

    report = {"repo": repo, "generated": datetime.now().isoformat(), "sections": {}}

    # ── Overview ──
    section(f"Overview: {repo}", f"{BOLD}{CYAN}")
    overview = get_overview(repo)
    if overview["nodes"]:
        total_symbols = sum(int(r.get("cnt", 0)) for r in overview["nodes"])
        out.print(f"  Total symbols: {BOLD}{total_symbols}{NC}")
        for row in overview["nodes"]:
            out.print(f"    {row['node_type']}: {row['cnt']}")
    if overview["relationships"]:
        out.print(f"\n  Relationships:")
        for row in overview["relationships"]:
            out.print(f"    {row['rel_type']}: {row['cnt']}")
    report["sections"]["overview"] = overview

    # ── Process Coverage ──
    procs = get_process_coverage(repo)
    if procs["total"] > 0:
        out.print(f"\n  Execution flows mapped: {BOLD}{procs['total']}{NC}")
        for row in procs["types"]:
            out.print(f"    {row['process_type']}: {row['cnt']}")
    report["sections"]["processes"] = procs

    # ═══════════════════════════════════════════════════════════
    # GOOD STUFF
    # ═══════════════════════════════════════════════════════════
    section("Strengths", f"{BOLD}{GREEN}")

    # Well-structured files
    well_structured = get_well_structured_files(repo)
    if well_structured:
        out.print(f"  {GREEN}Well-modularized files{NC} (3-8 functions each):")
        print_table(well_structured)
    report["sections"]["well_structured"] = well_structured

    # Architecture clusters
    clusters = get_architecture_clusters(repo)
    if clusters:
        # Highlight high-cohesion clusters
        good_clusters = [c for c in clusters if float(c.get("cohesion", 0)) > 0.5]
        if good_clusters:
            out.print(f"\n  {GREEN}High-cohesion clusters{NC} (>0.5 — well-organized code areas):")
            print_table(good_clusters)
    report["sections"]["architecture"] = clusters

    # Well-connected functions (good middleware/services)
    connected = get_well_connected_functions(repo)
    if connected:
        out.print(f"\n  {GREEN}Well-connected functions{NC} (both called by and calling others — good services):")
        print_table(connected)
    report["sections"]["well_connected"] = connected

    # ═══════════════════════════════════════════════════════════
    # IMPROVEMENT AREAS
    # ═══════════════════════════════════════════════════════════
    section("Improvement Areas", f"{BOLD}{YELLOW}")

    # Complexity hotspots
    hotspots = get_complexity_hotspots(repo, threshold=10)
    if hotspots:
        out.print(f"  {YELLOW}Complexity hotspots{NC} (files with 10+ functions — consider splitting):")
        print_table(hotspots)
        out.print(f"\n  {DIM}Suggestion: Break large files into focused modules.{NC}")
        out.print(f"  {DIM}Files with 20+ functions are strong candidates for refactoring.{NC}")
    else:
        out.print(f"  {GREEN}No complexity hotspots found.{NC}")
    report["sections"]["hotspots"] = hotspots

    # High blast radius
    blast = get_blast_radius(repo, threshold=8)
    if blast:
        out.print(f"\n  {YELLOW}High blast-radius functions{NC} (8+ callers — changes here break a lot):")
        print_table(blast)
        out.print(f"\n  {DIM}Suggestion: These need thorough test coverage and careful change management.{NC}")
        out.print(f"  {DIM}Consider adding integration tests for the top 5.{NC}")
    else:
        out.print(f"\n  {GREEN}No dangerously high blast-radius functions.{NC}")
    report["sections"]["blast_radius"] = blast

    # Cross-cluster coupling
    cross = get_cross_cluster_calls(repo)
    if cross:
        long_chains = [c for c in cross if int(c.get("steps", 0)) > 5]
        if long_chains:
            out.print(f"\n  {YELLOW}Long cross-cluster call chains{NC} (>5 steps — tight coupling):")
            print_table(long_chains)
            out.print(f"\n  {DIM}Suggestion: Long cross-cluster chains indicate tight coupling.{NC}")
            out.print(f"  {DIM}Consider introducing service boundaries or event-driven patterns.{NC}")
    report["sections"]["cross_cluster"] = cross

    # ═══════════════════════════════════════════════════════════
    # ISSUES
    # ═══════════════════════════════════════════════════════════
    section("Issues", f"{BOLD}{RED}")

    # Dead exports
    dead = get_dead_exports(repo)
    if dead:
        out.print(f"  {RED}Dead exports{NC} ({len(dead)} exported functions with no callers):")
        out.print(f"  {DIM}Note: Route handlers and framework hooks may appear here.{NC}\n")
        print_table(dead)
    else:
        out.print(f"  {GREEN}No dead exports found.{NC}")
    report["sections"]["dead_exports"] = dead

    # Orphaned files
    orphans = get_orphan_files(repo)
    if orphans:
        out.print(f"\n  {RED}Orphaned files{NC} ({len(orphans)} source files nothing imports):")
        out.print(f"  {DIM}Note: Framework auto-loaders may register these at runtime.{NC}\n")
        print_table(orphans)
    else:
        out.print(f"\n  {GREEN}No orphaned files found.{NC}")
    report["sections"]["orphan_files"] = orphans

    # ═══════════════════════════════════════════════════════════
    # SUMMARY
    # ═══════════════════════════════════════════════════════════
    section("Summary", f"{BOLD}{CYAN}")

    total_issues = len(dead) + len(orphans)
    total_improvements = len(hotspots) + len(blast) + len([c for c in cross if int(c.get("steps", 0)) > 5])
    total_strengths = len(well_structured) + len([c for c in clusters if float(c.get("cohesion", 0)) > 0.5]) + len(connected)

    out.print(f"  {GREEN}Strengths:    {total_strengths} positive signals{NC}")
    out.print(f"  {YELLOW}Improvements: {total_improvements} areas to address{NC}")
    out.print(f"  {RED}Issues:       {total_issues} items to investigate{NC}")
    out.print()

    # Health score (rough heuristic)
    total_symbols = sum(int(r.get("cnt", 0)) for r in overview.get("nodes", []))
    if total_symbols:
        issue_ratio = total_issues / max(total_symbols, 1)
        if issue_ratio < 0.05:
            grade = "A"
            color = GREEN
        elif issue_ratio < 0.10:
            grade = "B"
            color = GREEN
        elif issue_ratio < 0.20:
            grade = "C"
            color = YELLOW
        elif issue_ratio < 0.35:
            grade = "D"
            color = YELLOW
        else:
            grade = "F"
            color = RED
        out.print(f"  Health Grade: {BOLD}{color}{grade}{NC}  {DIM}(issues/symbols ratio: {issue_ratio:.1%}){NC}")
    out.print()

    report["sections"]["summary"] = {
        "strengths": total_strengths,
        "improvements": total_improvements,
        "issues": total_issues,
    }

    if output_json:
        out.print(json.dumps(report, indent=2, default=str))

    return report


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    global out

    parser = argparse.ArgumentParser(
        description="Comprehensive code health report using GitNexus knowledge graph"
    )
    parser.add_argument("--repo", type=str, help="Repository name (from gitnexus list)")
    parser.add_argument("--all", action="store_true", help="Run report for all indexed repos")
    parser.add_argument("--json", action="store_true", dest="output_json", help="Output JSON")
    parser.add_argument("--output", "-o", type=str, help="Save report to file (path)")

    # Individual report types
    parser.add_argument("--dead-code", action="store_true", help="Dead exports only")
    parser.add_argument("--hotspots", action="store_true", help="Complexity hotspots only")
    parser.add_argument("--blast-radius", action="store_true", help="High blast-radius functions only")
    parser.add_argument("--orphans", action="store_true", help="Orphaned files only")
    parser.add_argument("--architecture", action="store_true", help="Architecture clusters only")

    # Support subcommand-style invocation (engram code dead-code)
    parser.add_argument("report_type", nargs="?", default=None,
                        help="Report type when called as subcommand (dead-code, hotspots, blast-radius, orphans, architecture)")

    args = parser.parse_args()

    # Initialize output handler
    out = Output(file_path=args.output)

    # Check if a single report type was requested via flag or positional arg
    single_reports = {
        "dead-code": args.dead_code,
        "hotspots": args.hotspots,
        "blast-radius": args.blast_radius,
        "orphans": args.orphans,
        "architecture": args.architecture,
    }

    # Handle positional arg (e.g., `engram code dead-code`)
    if args.report_type and args.report_type in single_reports:
        single_reports[args.report_type] = True

    active_singles = [k for k, v in single_reports.items() if v]

    if not args.repo and not args.all:
        # Try to detect repo from current directory
        try:
            result = subprocess.run(
                ["npx", "gitnexus", "status"],
                capture_output=True, text=True, timeout=10
            )
            if result.returncode == 0:
                for line in result.stdout.split("\n"):
                    if "Repository:" in line:
                        args.repo = line.split(":")[-1].strip()
                        break
        except:
            pass

    if not args.repo and not args.all:
        print(f"{RED}Error: Specify --repo <name> or --all{NC}")
        print(f"{DIM}Available repos:{NC}")
        for r in get_indexed_repos():
            print(f"  {r}")
        sys.exit(1)

    repos = get_indexed_repos() if args.all else [args.repo]

    if not args.output_json:
        banner()

    for repo in repos:
        if active_singles:
            for report_type in active_singles:
                run_single_report(repo, report_type)
        else:
            run_full_report(repo, output_json=args.output_json)

    if not args.output_json:
        out.print(f"{GREEN}{'━' * 60}{NC}")
        out.print(f"{GREEN}  Report complete.{NC}")
        out.print(f"{GREEN}{'━' * 60}{NC}")
        out.print()

    # Save to file if --output was specified
    out.save()


if __name__ == "__main__":
    main()
