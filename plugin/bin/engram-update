#!/usr/bin/env bash
set -euo pipefail

# ── Resolve script location ────────────────────────────────────────────────
_resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    local dir
    while [ -L "$source" ]; do
        dir="$(cd -P "$(dirname "$source")" && pwd)"
        source="$(readlink "$source")"
        [[ "$source" != /* ]] && source="$dir/$source"
    done
    cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(_resolve_script_dir)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Find templates
if [ -d "$ROOT_DIR/plugin/templates/agent-template" ]; then
    TEMPLATE_DIR="$ROOT_DIR/plugin/templates/agent-template"
elif [ -d "$HOME/.openclaw/shared/agent-template" ]; then
    TEMPLATE_DIR="$HOME/.openclaw/shared/agent-template"
else
    echo "Error: Cannot find agent template directory" >&2
    exit 1
fi

# Source env config
_source_env_config() {
    local env_file="$HOME/.openclaw/extensions/engram/config/.engram.env"
    if [[ -f "$env_file" ]]; then
        while IFS= read -r line; do
            line="${line%%#*}"
            line="${line#"${line%%[![:space:]]*}"}"
            [[ -z "$line" ]] && continue
            if [[ "$line" == *=* ]]; then
                local key="${line%%=*}"
                local val="${line#*=}"
                if [[ -z "${!key:-}" ]]; then
                    export "$key=$val"
                fi
            fi
        done < "$env_file"
    fi
}
_source_env_config

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── OpenClaw root ───────────────────────────────────────────────────────────
OPENCLAW_ROOT="${OPENCLAW_ROOT:-$HOME/.openclaw}"

