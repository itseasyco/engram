    echo ""
    echo -e "${BOLD}${CYAN}"
    echo "  ███████╗███╗   ██╗ ██████╗ ██████╗  █████╗ ███╗   ███╗"
    echo "  ██╔════╝████╗  ██║██╔════╝ ██╔══██╗██╔══██╗████╗ ████║"
    echo "  █████╗  ██╔██╗ ██║██║  ███╗██████╔╝███████║██╔████╔██║"
    echo "  ██╔══╝  ██║╚██╗██║██║   ██║██╔══██╗██╔══██║██║╚██╔╝██║"
    echo "  ███████╗██║ ╚████║╚██████╔╝██║  ██║██║  ██║██║ ╚═╝ ██║"
    echo "  ╚══════╝╚═╝  ╚═══╝ ╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═╝╚═╝     ╚═╝"
    echo -e "${NC}"
    echo -e "${BOLD}${YELLOW}"
    echo "  ██╗   ██╗██████╗ ██████╗  █████╗ ████████╗███████╗"
    echo "  ██║   ██║██╔══██╗██╔══██╗██╔══██╗╚══██╔══╝██╔════╝"
    echo "  ██║   ██║██████╔╝██║  ██║███████║   ██║   █████╗  "
    echo "  ██║   ██║██╔═══╝ ██║  ██║██╔══██║   ██║   ██╔══╝  "
    echo "  ╚██████╔╝██║     ██████╔╝██║  ██║   ██║   ███████╗"
    echo "   ╚═════╝ ╚═╝     ╚═════╝ ╚═╝  ╚═╝   ╚═╝   ╚══════╝"
    echo -e "${NC}"
    echo ""
}

# ── Usage ───────────────────────────────────────────────────────────────────
show_help() {
    show_banner
    echo -e "${BOLD}USAGE${NC}"
    echo "  engram update [options]"
    echo ""
    echo -e "${BOLD}OPTIONS${NC}"
    echo "  --agent <name>     Update a specific agent workspace"
    echo "  --all              Update all (workspaces + platforms + shared)"
    echo "  --platforms        Update platform configs only (hooks, MCP, extensions)"
    echo "  --workspaces       Update agent workspaces only"
    echo "  --dry-run          Preview changes without applying"
    echo "  --force            Apply changes without confirmation"
    echo "  --shared           Also update ~/.openclaw/shared/ templates"
    echo "  -h, --help         Show this help"
    echo ""
    echo -e "${BOLD}WHAT IT DOES${NC}"
    echo ""
    echo -e "  ${CYAN}Platforms${NC} (auto-detected)"
    echo "  - Claude Code: updates hook paths and MCP server config"
    echo "  - OpenClaw: syncs extension files from latest install"
    echo "  - Codex: checks MCP config"
    echo ""
    echo -e "  ${CYAN}Workspaces${NC}"
    echo "  - Migrates old-format agent files to current template"
    echo "  - Adds missing template files, creates memory/ dirs"
    echo "  - Removes deprecated references and files"
    echo "  - Updates ~/.openclaw/shared/agent-template/"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo "  engram update                         # Update everything"
    echo "  engram update --dry-run               # Preview all changes"
    echo "  engram update --platforms              # Just update hooks/MCP/extensions"
    echo "  engram update --agent alex             # Update one workspace"
    echo ""
}

# ── Template files we expect ────────────────────────────────────────────────
TEMPLATE_FILES=(AGENTS.md SOUL.md IDENTITY.md USER.md HEARTBEAT.md TOOLS.md)

# Old boilerplate markers — if AGENTS.md contains any of these, it's old format
OLD_MARKERS=(
    "SUB-AGENT.md"
    "DISCORD.md"
    "TEAM.md"
    "SAFETY.md"
)

# ── Detect workspace version ────────────────────────────────────────────────
detect_version() {
    local ws_dir="$1"
    local agents_file="$ws_dir/AGENTS.md"

    # Check for old markers
    if [[ -f "$agents_file" ]]; then
        for marker in "${OLD_MARKERS[@]}"; do
            if grep -q "$marker" "$agents_file" 2>/dev/null; then
                echo "old"
                return
            fi
        done
    fi

    # Check for new-format indicators
    if [[ -f "$ws_dir/MEMORY.md" ]] && ! [[ -f "$ws_dir/BOOTSTRAP.md" ]]; then
        echo "current"
        return
    fi

    # Has new AGENTS.md but no MEMORY.md yet — partially updated
    if [[ -f "$agents_file" ]] && grep -q "Every Session" "$agents_file" 2>/dev/null; then
        echo "partial"
        return
    fi

    echo "unknown"
}

# ── Extract agent name from workspace path ──────────────────────────────────
agent_name_from_path() {
    local ws_dir="$1"
    basename "$ws_dir" | sed 's/^workspace-//'
}

# ── Extract agent emoji from IDENTITY.md or SOUL.md ────────────────────────
agent_emoji_from_ws() {
    local ws_dir="$1"
    local identity="$ws_dir/IDENTITY.md"
    local soul="$ws_dir/SOUL.md"

    # Try IDENTITY.md first
    if [[ -f "$identity" ]]; then
        local emoji
        emoji=$(grep -oP '(?<=Emoji:\s).*' "$identity" 2>/dev/null | head -1 | tr -d ' ')
        if [[ -n "$emoji" ]]; then
            echo "$emoji"
            return
        fi
    fi

    # Try first line of SOUL.md or AGENTS.md
    for file in "$soul" "$ws_dir/AGENTS.md"; do
        if [[ -f "$file" ]]; then
            local first_emoji
            # Extract emoji from title line (e.g., "# SOUL — Alex 🚀")
            first_emoji=$(head -1 "$file" | grep -oE '[\x{1F300}-\x{1F9FF}]|[\x{2600}-\x{27BF}]' 2>/dev/null | head -1)
            if [[ -n "$first_emoji" ]]; then
                echo "$first_emoji"
                return
            fi
        fi
    done

    echo ""
}

# ── Update a single workspace ───────────────────────────────────────────────
update_workspace() {
    local ws_dir="$1"
    local dry_run="$2"
    local name
    name=$(agent_name_from_path "$ws_dir")
    local emoji
    emoji=$(agent_emoji_from_ws "$ws_dir")
    local version
    version=$(detect_version "$ws_dir")

    local changes=0

    echo -e "  ${BOLD}${name}${NC} ${emoji}  ${DIM}(${version} format)${NC}"

    # ── 1. Check AGENTS.md ──────────────────────────────────────────────
    local agents_file="$ws_dir/AGENTS.md"
    if [[ "$version" == "old" ]]; then
        changes=$((changes + 1))
        if [[ "$dry_run" == "true" ]]; then
            echo -e "    ${YELLOW}would update${NC}  AGENTS.md (remove old boilerplate, add new session/memory/safety sections)"
        else
            # Preserve any custom content after the boilerplate
            local display_name="${name^}"  # capitalize first letter
            cat > "$agents_file" <<AGENTS_EOF
# AGENTS.md — ${display_name} ${emoji}

## Every Session

Before doing anything else:
1. Read \`SOUL.md\` — this is who you are
2. Read \`USER.md\` — this is who you're helping
3. Read \`TOOLS.md\` — what you have access to

## References

Read these from \`~/.openclaw/shared/\` as needed:
- \`ENGRAM.md\` — memory workflow (read every session)

## Memory

You wake up fresh each session. Your files are your continuity.
- **Daily notes:** \`memory/YYYY-MM-DD.md\` — raw logs of what happened
- **Long-term:** \`MEMORY.md\` — curated memories

Capture what matters. Decisions, context, things to remember.

## Safety

- Don't exfiltrate private data. Ever.
- Don't run destructive commands without asking.
- \`trash\` > \`rm\`
- When in doubt, ask.
AGENTS_EOF
            echo -e "    ${GREEN}updated${NC}       AGENTS.md (replaced old boilerplate)"
        fi
    fi

    # ── 2. Create memory/ directory if missing ──────────────────────────
    if ! [[ -d "$ws_dir/memory" ]]; then
        changes=$((changes + 1))
        if [[ "$dry_run" == "true" ]]; then
            echo -e "    ${YELLOW}would create${NC}  memory/ directory"
        else
            mkdir -p "$ws_dir/memory"
            echo -e "    ${GREEN}created${NC}       memory/"
        fi
    fi

    # ── 3. Add missing template files ───────────────────────────────────
    for tpl in "${TEMPLATE_FILES[@]}"; do
        if ! [[ -f "$ws_dir/$tpl" ]]; then
            changes=$((changes + 1))
            if [[ "$dry_run" == "true" ]]; then
                echo -e "    ${YELLOW}would add${NC}     $tpl (missing)"
            else
                local display_name="${name^}"
                sed -e "s/{{NAME}}/${display_name}/g" \
                    -e "s/{{EMOJI}}/${emoji}/g" \
                    -e "s/{{ROLE_TITLE}}/AI Agent/g" \
                    -e "s/{{ROLE_DESCRIPTION}}//g" \
                    -e "s/{{EXPERTISE}}//g" \
                    -e "s/{{RULES}}//g" \
                    -e "s/{{VIBE}}//g" \
                    -e "s/{{WORKFLOW}}//g" \
                    -e "s/{{AGENT_TYPE}}/primary/g" \
                    -e "s/{{PARENT}}/none/g" \
                    "$TEMPLATE_DIR/$tpl" > "$ws_dir/$tpl"
                echo -e "    ${GREEN}added${NC}         $tpl"
            fi
        fi
    done

    # ── 4. Remove deprecated shared references ─────────────────────────
    # Check if AGENTS.md still references deprecated files
    if [[ -f "$agents_file" ]]; then
        for old_ref in "SUB-AGENT.md" "DISCORD.md" "TEAM.md" "SAFETY.md"; do
            if grep -q "$old_ref" "$agents_file" 2>/dev/null; then
                changes=$((changes + 1))
                if [[ "$dry_run" == "true" ]]; then
                    echo -e "    ${YELLOW}would remove${NC}  reference to $old_ref in AGENTS.md"
                else
                    # Remove lines containing the old reference
                    local tmp_file
                    tmp_file=$(mktemp)
                    grep -v "$old_ref" "$agents_file" > "$tmp_file" || true
                    mv "$tmp_file" "$agents_file"
                    echo -e "    ${GREEN}removed${NC}       reference to $old_ref"
                fi
            fi
        done
    fi

    # ── 5. Clean up deprecated files in the workspace ──────────────────
    for deprecated in "discord-channels.json"; do
        if [[ -f "$ws_dir/$deprecated" ]]; then
            changes=$((changes + 1))
            if [[ "$dry_run" == "true" ]]; then
                echo -e "    ${YELLOW}found${NC}         $deprecated (deprecated, would offer to remove)"
            else
                echo -e "    ${YELLOW}found${NC}         $deprecated (deprecated)"
                echo -en "    Remove $deprecated? [y/N]: "
                read -r confirm
                case "$confirm" in
                    [yY]|[yY][eE][sS])
                        rm "$ws_dir/$deprecated"
                        echo -e "    ${GREEN}removed${NC}       $deprecated"
                        ;;
                    *)
                        echo -e "    ${DIM}kept${NC}          $deprecated"
                        ;;
                esac
            fi
        fi
    done

    # ── 6. Detect stale BOOTSTRAP.md ───────────────────────────────────
    if [[ -f "$ws_dir/BOOTSTRAP.md" ]]; then
        # If SOUL.md has been customized (doesn't contain {{NAME}}), bootstrap is stale
        if [[ -f "$ws_dir/SOUL.md" ]] && ! grep -q '{{NAME}}' "$ws_dir/SOUL.md" 2>/dev/null; then
            changes=$((changes + 1))
            if [[ "$dry_run" == "true" ]]; then
                echo -e "    ${YELLOW}found${NC}         BOOTSTRAP.md (stale — agent appears configured, would offer to remove)"
            else
                echo -e "    ${YELLOW}found${NC}         BOOTSTRAP.md (stale — agent appears configured)"
                echo -en "    Remove stale BOOTSTRAP.md? [y/N]: "
                read -r confirm
                case "$confirm" in
                    [yY]|[yY][eE][sS])
                        rm "$ws_dir/BOOTSTRAP.md"
                        echo -e "    ${GREEN}removed${NC}       BOOTSTRAP.md"
                        ;;
                    *)
                        echo -e "    ${DIM}kept${NC}          BOOTSTRAP.md"
                        ;;
                esac
            fi
        fi
    fi

    # ── 7. Check TOOLS.md for engram section ───────────────────────────
    if [[ -f "$ws_dir/TOOLS.md" ]]; then
        if ! grep -qi "engram" "$ws_dir/TOOLS.md" 2>/dev/null; then
            changes=$((changes + 1))
            if [[ "$dry_run" == "true" ]]; then
                echo -e "    ${YELLOW}would add${NC}     Engram tools section to TOOLS.md"
            else
                cat >> "$ws_dir/TOOLS.md" <<'TOOLS_APPEND'

## Engram

Memory, safety, and knowledge tools are available via Engram MCP tools.
Run `engram status` to verify. Key tools: `engram_memory_query`, `engram_promote_fact`, `engram_vault_status`.
TOOLS_APPEND
                echo -e "    ${GREEN}added${NC}         Engram section to TOOLS.md"
            fi
        fi
    fi

    if [[ "$changes" -eq 0 ]]; then
        echo -e "    ${GREEN}up to date${NC}"
    fi

    echo ""
    return 0
}

# ── Platform detection ─────────────────────────────────────────────────────
detect_platforms() {
    local platforms=()

    # Claude Code: check for ~/.claude/settings.json
    if [[ -f "$HOME/.claude/settings.json" ]]; then
        platforms+=("claude-code")
    fi

    # OpenClaw: check for extension dir
    if [[ -d "$HOME/.openclaw/extensions/engram" ]]; then
        platforms+=("openclaw")
    fi

    # Codex: check for ~/.codex/
    if [[ -d "$HOME/.codex" ]]; then
        platforms+=("codex")
    fi

    echo "${platforms[*]}"
}

# ── Resolve current engram plugin dir (from npm install) ───────────────────
resolve_engram_plugin_dir() {
    # This script is at plugin/bin/engram-update, so plugin dir is one up
    echo "$(cd "$SCRIPT_DIR/.." && pwd)"
}

# ── Update Claude Code hooks ──────────────────────────────────────────────
update_claude_code_hooks() {
    local dry_run="$1"
    local settings_file="$HOME/.claude/settings.json"
    local plugin_dir
    plugin_dir="$(resolve_engram_plugin_dir)"
    local adapters_dir="$plugin_dir/hooks/adapters"

    echo -e "  ${BOLD}Claude Code Hooks${NC}"

    if ! [[ -f "$settings_file" ]]; then
        echo -e "    ${DIM}No settings.json found${NC}"
        echo ""
        return
    fi

    # Use python3 to inspect and update hook paths
    local result
    result=$(python3 -c "
import json, sys

settings_file = '$settings_file'
adapters_dir = '$adapters_dir'
dry_run = '$dry_run' == 'true'

with open(settings_file) as f:
    settings = json.load(f)

hooks = settings.get('hooks', {})
if not hooks:
    print('NO_HOOKS')
    sys.exit(0)

# Map adapter filenames to their purpose
ENGRAM_ADAPTERS = {
    'claude-session-start.sh': 'SessionStart',
    'claude-pretool-guard.sh': 'PreToolUse',
    'claude-write-validate.sh': 'PostToolUse',
    'claude-stop-quality-gate.sh': 'Stop',
}

changes = 0
missing = []

# Check each hook event for engram hooks that need path updates
for event, matchers in hooks.items():
    for matcher in matchers:
        for hook in matcher.get('hooks', []):
            cmd = hook.get('command', '')
            if 'engram' not in cmd.lower():
                continue
            # Extract the adapter filename
            basename = cmd.rsplit('/', 1)[-1] if '/' in cmd else cmd
            new_path = f'{adapters_dir}/{basename}'
            if cmd != new_path:
                changes += 1
                if not dry_run:
                    hook['command'] = new_path

# Check which engram hooks are installed
installed_adapters = set()
for event, matchers in hooks.items():
    for matcher in matchers:
        for hook in matcher.get('hooks', []):
            cmd = hook.get('command', '')
            if 'engram' in cmd.lower():
                basename = cmd.rsplit('/', 1)[-1] if '/' in cmd else cmd
                installed_adapters.add(basename)

for adapter in ENGRAM_ADAPTERS:
    if adapter not in installed_adapters:
        missing.append(adapter)

if not dry_run and changes > 0:
    with open(settings_file, 'w') as f:
        json.dump(settings, f, indent=2)
        f.write('\n')

# Output status
if changes > 0:
    print(f'UPDATED:{changes}')
elif missing:
    print(f'MISSING:{\";\".join(missing)}')
else:
    print('OK')
" 2>&1)

    case "$result" in
        UPDATED:*)
            local count="${result#UPDATED:}"
            if [[ "$dry_run" == "true" ]]; then
                echo -e "    ${YELLOW}would update${NC}  $count hook path(s) to current install location"
            else
                echo -e "    ${GREEN}updated${NC}       $count hook path(s) to: $adapters_dir/"
            fi
            ;;
        MISSING:*)
            local missing_list="${result#MISSING:}"
            echo -e "    ${YELLOW}missing${NC}       hooks not installed: ${missing_list//;/, }"
            if [[ "$dry_run" == "false" ]]; then
                echo -e "    ${DIM}Run the installer to add missing hooks: setup-claude-code.sh --global${NC}"
            fi
            ;;
        OK)
            echo -e "    ${GREEN}up to date${NC}    hook paths point to current install"
            ;;
        NO_HOOKS)
            echo -e "    ${DIM}No hooks configured — run installer to set up${NC}"
            ;;
        *)
            echo -e "    ${RED}error${NC}         $result"
            ;;
    esac

    echo ""
}

# ── Update Claude Code MCP config ─────────────────────────────────────────
update_claude_code_mcp() {
    local dry_run="$1"
    local plugin_dir
    plugin_dir="$(resolve_engram_plugin_dir)"
    local server_mjs="$plugin_dir/mcp/server.mjs"

    echo -e "  ${BOLD}Claude Code MCP Server${NC}"

    # Check both ~/.claude.json and project-level .mcp.json
    local targets=()
    [[ -f "$HOME/.claude.json" ]] && targets+=("$HOME/.claude.json")

    if [[ ${#targets[@]} -eq 0 ]]; then
        echo -e "    ${DIM}No MCP config found — run installer to set up${NC}"
        echo ""
        return
    fi

    local node_bin
    node_bin="$(command -v node 2>/dev/null || which node 2>/dev/null)"

    for target in "${targets[@]}"; do
        local result
        result=$(python3 -c "
import json, sys, os

target = '$target'
plugin_dir = '$plugin_dir'
server_mjs = '$server_mjs'
node_bin = '$node_bin'
dry_run = '$dry_run' == 'true'

with open(target) as f:
    data = json.load(f)

mcp = data.get('mcpServers', {}).get('engram')
if not mcp:
    print('NOT_INSTALLED')
    sys.exit(0)

changes = 0

# Check command (node path)
if mcp.get('command', '') != node_bin:
    changes += 1
    if not dry_run:
        mcp['command'] = node_bin

# Check args (server.mjs path)
args = mcp.get('args', [])
if args and args[0] != server_mjs:
    changes += 1
    if not dry_run:
        mcp['args'] = [server_mjs]

# Check env ENGRAM_DIR
env = mcp.get('env', {})
if env.get('ENGRAM_DIR', '') != plugin_dir:
    changes += 1
    if not dry_run:
        mcp.setdefault('env', {})['ENGRAM_DIR'] = plugin_dir

# Preserve vault path — don't overwrite user's vault setting
# Just make sure it exists
if 'LACP_OBSIDIAN_VAULT' not in env:
    changes += 1
    # Try to resolve from .engram.env
    vault = os.path.expanduser('~/.openclaw/data/knowledge')
    env_file = os.path.expanduser('~/.openclaw/extensions/engram/config/.engram.env')
    if os.path.isfile(env_file):
        for line in open(env_file):
            line = line.strip()
            if line.startswith('LACP_OBSIDIAN_VAULT='):
                vault = line.split('=', 1)[1].strip().strip('\"').strip(\"'\")
                break
    if not dry_run:
        mcp.setdefault('env', {})['LACP_OBSIDIAN_VAULT'] = vault

if not dry_run and changes > 0:
    with open(target, 'w') as f:
        json.dump(data, f, indent=2)
        f.write('\n')

if changes > 0:
    print(f'UPDATED:{changes}')
else:
    print('OK')
" 2>&1)

        local basename
        basename=$(basename "$target")
        case "$result" in
            UPDATED:*)
                local count="${result#UPDATED:}"
                if [[ "$dry_run" == "true" ]]; then
                    echo -e "    ${YELLOW}would update${NC}  $count setting(s) in $basename"
                else
                    echo -e "    ${GREEN}updated${NC}       $count setting(s) in $basename"
                fi
                ;;
            OK)
                echo -e "    ${GREEN}up to date${NC}    $basename"
                ;;
            NOT_INSTALLED)
                echo -e "    ${DIM}engram not in $basename — run installer to set up${NC}"
                ;;
            *)
                echo -e "    ${RED}error${NC}         $result"
                ;;
        esac
    done

    echo ""
}

# ── Update OpenClaw extension ─────────────────────────────────────────────
update_openclaw_extension() {
    local dry_run="$1"
    local ext_dir="$HOME/.openclaw/extensions/engram"
    local plugin_dir
    plugin_dir="$(resolve_engram_plugin_dir)"

    echo -e "  ${BOLD}OpenClaw Extension${NC}"

    if ! [[ -d "$ext_dir" ]]; then
        echo -e "    ${DIM}Not installed${NC}"
        echo ""
        return
    fi

    local changes=0

    # Sync key directories from npm install to extension
    local sync_dirs=("bin" "lib" "hooks" "mcp" "rules" "policy")
    for dir in "${sync_dirs[@]}"; do
        local src="$plugin_dir/$dir"
        local dst="$ext_dir/$dir"
        if [[ -d "$src" ]]; then
            # Check if any files differ
            local diff_count=0
            if [[ -d "$dst" ]]; then
                diff_count=$(diff -rq "$src" "$dst" 2>/dev/null | wc -l | tr -d ' ' || true)
            else
                diff_count=1
            fi
            if [[ "$diff_count" -gt 0 ]]; then
                changes=$((changes + 1))
                if [[ "$dry_run" == "true" ]]; then
                    echo -e "    ${YELLOW}would sync${NC}    $dir/ ($diff_count file(s) differ)"
                else
                    rsync -a --delete "$src/" "$dst/"
                    echo -e "    ${GREEN}synced${NC}        $dir/"
                fi
            fi
        fi
    done

    # Sync key root files
    local sync_files=("index.ts" "openclaw.plugin.json" "plugin.json" "package.json")
    for file in "${sync_files[@]}"; do
        local src="$plugin_dir/../$file"
        # For files at package root (one above plugin/)
        if ! [[ -f "$src" ]]; then
            src="$ROOT_DIR/$file"
        fi
        if [[ -f "$src" ]] && [[ -f "$ext_dir/$file" ]]; then
            if ! diff -q "$src" "$ext_dir/$file" >/dev/null 2>&1; then
                changes=$((changes + 1))
                if [[ "$dry_run" == "true" ]]; then
                    echo -e "    ${YELLOW}would update${NC}  $file"
                else
                    cp "$src" "$ext_dir/$file"
                    echo -e "    ${GREEN}updated${NC}       $file"
                fi
            fi
        fi
    done

    if [[ "$changes" -eq 0 ]]; then
        echo -e "    ${GREEN}up to date${NC}"
    fi

    echo ""
}

# ── Update Codex config ───────────────────────────────────────────────────
update_codex() {
    local dry_run="$1"
    local plugin_dir
    plugin_dir="$(resolve_engram_plugin_dir)"

    echo -e "  ${BOLD}Codex${NC}"

    if ! [[ -d "$HOME/.codex" ]]; then
        echo -e "    ${DIM}Not installed${NC}"
        echo ""
        return
    fi

    # Check if engram AGENTS.md or instructions exist in codex
    local codex_agents="$HOME/.codex/AGENTS.md"
    if [[ -f "$codex_agents" ]] && grep -qi "engram" "$codex_agents" 2>/dev/null; then
        echo -e "    ${GREEN}up to date${NC}    AGENTS.md references engram"
    else
        echo -e "    ${DIM}No engram integration detected in Codex${NC}"
        echo -e "    ${DIM}Codex MCP: copy engram MCP config to .codex/mcp.json in each repo${NC}"
    fi

    echo ""
}

# ── Update shared templates ─────────────────────────────────────────────────
update_shared() {
    local dry_run="$1"
    local shared_dir="$OPENCLAW_ROOT/shared/agent-template"

    echo -e "  ${BOLD}Shared Templates${NC}  ${DIM}($shared_dir)${NC}"

    if ! [[ -d "$shared_dir" ]]; then
        if [[ "$dry_run" == "true" ]]; then
            echo -e "    ${YELLOW}would create${NC}  $shared_dir"
        else
            mkdir -p "$shared_dir"
            echo -e "    ${GREEN}created${NC}       $shared_dir"
        fi
    fi

    local changes=0
    for tpl in "${TEMPLATE_FILES[@]}" BOOTSTRAP.md; do
        local src="$TEMPLATE_DIR/$tpl"
        local dst="$shared_dir/$tpl"

        if ! [[ -f "$src" ]]; then
            continue
        fi

        if ! [[ -f "$dst" ]]; then
            changes=$((changes + 1))
            if [[ "$dry_run" == "true" ]]; then
                echo -e "    ${YELLOW}would add${NC}     $tpl"
            else
                cp "$src" "$dst"
                echo -e "    ${GREEN}added${NC}         $tpl"
            fi
        elif ! diff -q "$src" "$dst" >/dev/null 2>&1; then
            changes=$((changes + 1))
            if [[ "$dry_run" == "true" ]]; then
                echo -e "    ${YELLOW}would update${NC}  $tpl (template changed)"
            else
                cp "$src" "$dst"
                echo -e "    ${GREEN}updated${NC}       $tpl"
            fi
        fi
    done

    # Remove deprecated shared files
    for deprecated in "SUB-AGENT.md" "DISCORD.md" "TEAM.md" "SAFETY.md"; do
        if [[ -f "$OPENCLAW_ROOT/shared/$deprecated" ]]; then
            changes=$((changes + 1))
            if [[ "$dry_run" == "true" ]]; then
                echo -e "    ${YELLOW}would remove${NC}  shared/$deprecated (deprecated)"
            else
                rm "$OPENCLAW_ROOT/shared/$deprecated"
                echo -e "    ${GREEN}removed${NC}       shared/$deprecated"
            fi
        fi
    done

    if [[ "$changes" -eq 0 ]]; then
        echo -e "    ${GREEN}up to date${NC}"
    fi

    echo ""
}

# ── Main ────────────────────────────────────────────────────────────────────
DRY_RUN="false"
FORCE="false"
TARGET_AGENT=""
UPDATE_ALL="false"
UPDATE_SHARED="false"
UPDATE_PLATFORMS="false"
UPDATE_WORKSPACES="false"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --agent)       TARGET_AGENT="$2"; shift 2 ;;
        --all)         UPDATE_ALL="true"; shift ;;
        --platforms)   UPDATE_PLATFORMS="true"; shift ;;
        --workspaces)  UPDATE_WORKSPACES="true"; shift ;;
        --dry-run)     DRY_RUN="true"; shift ;;
        --force)       FORCE="true"; shift ;;
        --shared)      UPDATE_SHARED="true"; shift ;;
        -h|--help)     show_help; exit 0 ;;
        *)             echo -e "${RED}Unknown option: $1${NC}"; show_help; exit 1 ;;
    esac
done

# Default: update everything
if [[ -z "$TARGET_AGENT" ]] && [[ "$UPDATE_ALL" == "false" ]] \
   && [[ "$UPDATE_PLATFORMS" == "false" ]] && [[ "$UPDATE_WORKSPACES" == "false" ]]; then
    UPDATE_ALL="true"
    UPDATE_SHARED="true"
fi

# --all means platforms + workspaces + shared
if [[ "$UPDATE_ALL" == "true" ]]; then
    UPDATE_PLATFORMS="true"
    UPDATE_WORKSPACES="true"
    UPDATE_SHARED="true"
fi

show_banner

if [[ "$DRY_RUN" == "true" ]]; then
    echo -e "  ${YELLOW}DRY RUN — no changes will be made${NC}"
    echo ""
fi

# ── Platform detection ────────────────────────────────────────────────────
detected_platforms="$(detect_platforms)"
echo -e "${BOLD}Detected Platforms${NC}"
if [[ -z "$detected_platforms" ]]; then
    echo -e "  ${DIM}None detected${NC}"
else
    for p in $detected_platforms; do
        case "$p" in
            claude-code) echo -e "  ${GREEN}✓${NC} Claude Code  ${DIM}(~/.claude/settings.json)${NC}" ;;
            openclaw)    echo -e "  ${GREEN}✓${NC} OpenClaw     ${DIM}(~/.openclaw/extensions/engram/)${NC}" ;;
            codex)       echo -e "  ${GREEN}✓${NC} Codex        ${DIM}(~/.codex/)${NC}" ;;
        esac
    done
fi
echo ""

# ── Platform updates ──────────────────────────────────────────────────────
if [[ "$UPDATE_PLATFORMS" == "true" ]]; then
    echo -e "${BOLD}Platform Updates${NC}"
    echo ""

    for p in $detected_platforms; do
        case "$p" in
            claude-code)
                update_claude_code_hooks "$DRY_RUN"
                update_claude_code_mcp "$DRY_RUN"
                ;;
            openclaw)
                update_openclaw_extension "$DRY_RUN"
                ;;
            codex)
                update_codex "$DRY_RUN"
                ;;
        esac
    done
fi

# ── Shared templates ──────────────────────────────────────────────────────
if [[ "$UPDATE_SHARED" == "true" ]]; then
    update_shared "$DRY_RUN"
fi

# ── Workspaces ────────────────────────────────────────────────────────────
total_workspaces=0

if [[ "$UPDATE_WORKSPACES" == "true" ]] || [[ -n "$TARGET_AGENT" ]]; then
    # Collect workspaces
    if [[ -n "$TARGET_AGENT" ]]; then
        ws_dir="$OPENCLAW_ROOT/workspace-${TARGET_AGENT}"
        if ! [[ -d "$ws_dir" ]]; then
            echo -e "  ${RED}Workspace not found: $ws_dir${NC}"
            exit 1
        fi
        workspaces=("$ws_dir")
    else
        workspaces=()
        for ws in "$OPENCLAW_ROOT"/workspace-*/; do
            [[ -d "$ws" ]] && workspaces+=("$ws")
        done
    fi

    if [[ ${#workspaces[@]} -gt 0 ]]; then
        echo -e "${BOLD}Agent Workspaces${NC}  ${DIM}(${#workspaces[@]} found)${NC}"
        echo ""

        for ws in "${workspaces[@]}"; do
            ws="${ws%/}"  # trim trailing slash
            update_workspace "$ws" "$DRY_RUN"
            total_workspaces=$((total_workspaces + 1))
        done
    else
        echo -e "  ${DIM}No workspaces found.${NC}"
        echo ""
    fi
fi

# ── Summary ───────────────────────────────────────────────────────────────
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
if [[ "$total_workspaces" -gt 0 ]]; then
    echo -e "  Scanned ${BOLD}${total_workspaces}${NC} workspace(s)"
fi
if [[ -n "$detected_platforms" ]]; then
    echo -e "  Checked ${BOLD}$(echo "$detected_platforms" | wc -w | tr -d ' ')${NC} platform(s)"
fi
if [[ "$DRY_RUN" == "true" ]]; then
    echo -e "  ${YELLOW}Dry run complete. Run without --dry-run to apply changes.${NC}"
else
    echo -e "  ${GREEN}Update complete.${NC}"
fi
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
