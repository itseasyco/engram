#!/usr/bin/env bash
#
# openclaw-brain-stack — Main orchestrator for 5-layer memory system
# Initializes, manages, and expands all memory layers
#

set -euo pipefail

PROG=$(basename "$0")
VERSION="1.0.0"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default configuration
LACP_OBSIDIAN_VAULT="${LACP_OBSIDIAN_VAULT:-$HOME/obsidian/vault}"
SESSION_MEMORY_ROOT="${SESSION_MEMORY_ROOT:-$HOME/.openclaw/projects}"
LACP_KNOWLEDGE_ROOT="${LACP_KNOWLEDGE_ROOT:-$HOME/.openclaw/data/knowledge}"

# ============================================================================
# Utilities
# ============================================================================

log_info() {
  echo -e "${BLUE}[INFO]${NC} $*" >&2
}

log_success() {
  echo -e "${GREEN}[✓]${NC} $*" >&2
}

log_warn() {
  echo -e "${YELLOW}[WARN]${NC} $*" >&2
}

log_error() {
  echo -e "${RED}[ERROR]${NC} $*" >&2
}

die() {
  log_error "$@"
  exit 1
}

# Normalize path to slug: /Users/alice/repos/project -> Users-alice-repos-project
path_to_slug() {
  local path="$1"
  # Expand ~ to home
  path="${path/#\~/$HOME}"
  # Make absolute
  path="$(cd "$path" 2>/dev/null && pwd)" || path="$1"
  # Convert to slug: remove leading /, replace / with -, remove trailing -
  slug=$(echo "$path" | sed 's|^/||; s|/|-|g; s|-$||')
  echo "$slug"
}

# ============================================================================
# Layer 1: Session Memory Initialization
# ============================================================================

init_session_memory() {
  local project="$1"
  local agent="${2:-unknown}"
  local slug
  
  slug=$(path_to_slug "$project")
  local memory_dir="$SESSION_MEMORY_ROOT/$slug/memory"
  
  log_info "Initializing Layer 1 Session Memory..."
  log_info "  Project: $project"
  log_info "  Slug: $slug"
  log_info "  Memory dir: $memory_dir"
  
  mkdir -p "$memory_dir/archive"
  
  # 1. MEMORY.md — Project-wide long-term memory
  if [ ! -f "$memory_dir/MEMORY.md" ]; then
    cat > "$memory_dir/MEMORY.md" <<'EOF'
# Project Memory

## Context
[Project overview, key decisions, stakeholders]

## Architecture
[High-level codebase structure, patterns]

## Active Issues
[Known blockers, TODOs, risks]

## Learnings
[Things that worked, lessons learned]

## Team
[Team members, responsibilities]
EOF
    log_success "Created MEMORY.md"
  fi
  
  # 2. debugging.md — Debugging patterns
  if [ ! -f "$memory_dir/debugging.md" ]; then
    cat > "$memory_dir/debugging.md" <<'EOF'
# Debugging Patterns

## Common Issues
[Known error categories with solutions]

## Tools & Workflows
[Debugging commands, profiling techniques]

## Stack-Specific Patterns
[Language/framework-specific gotchas]

## Checklist
- [ ] Check logs
- [ ] Verify configuration
- [ ] Run tests
- [ ] Check for recent changes
EOF
    log_success "Created debugging.md"
  fi
  
  # 3. patterns.md — Architectural patterns
  if [ ! -f "$memory_dir/patterns.md" ]; then
    cat > "$memory_dir/patterns.md" <<'EOF'
# Architecture Patterns

## Design Patterns Used
[Factory, Observer, Command, etc.]

## Anti-Patterns to Avoid
[Known pitfalls]

## Module Organization
[How code is structured]

## Naming Conventions
- Classes: PascalCase
- Functions: camelCase
- Constants: UPPER_SNAKE_CASE
EOF
    log_success "Created patterns.md"
  fi
  
  # 4. architecture.md — Codebase architecture
  if [ ! -f "$memory_dir/architecture.md" ]; then
    cat > "$memory_dir/architecture.md" <<'EOF'
# Architecture Overview

## Layers
[Frontend, API, Data, etc.]

## Data Flow
[Request → processing → response]

## Integration Points
[External services, APIs]

## Technology Stack
[Languages, frameworks, databases]
EOF
    log_success "Created architecture.md"
  fi
  
  # 5. preferences.md — Agent/human preferences
  if [ ! -f "$memory_dir/preferences.md" ]; then
    cat > "$memory_dir/preferences.md" <<EOF
# Project Preferences

## Agent (${agent})
- Coding style: [tabs/spaces, naming conventions]
- Testing strategy: [unit/integration/e2e]
- Documentation style: [markdown, doxygen, etc.]

## Human
- Communication style: [detailed/concise]
- Review cadence: [after each session/weekly/etc.]
- Escalation triggers: [when to ask for help]

## Project Rules
- Auto-format on save: true
- Min test coverage: 80%
- Max file size: 500 lines
EOF
    log_success "Created preferences.md"
  fi
  
  # 6. Create .memory-index.json
  cat > "$memory_dir/.memory-index.json" <<EOF
{
  "project": "$project",
  "slug": "$slug",
  "agent": "$agent",
  "initialized_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "last_updated": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "layers_enabled": {
    "layer1_session_memory": true,
    "layer2_knowledge_graph": false,
    "layer3_ingestion": false,
    "layer4_code_intelligence": false,
    "layer5_provenance": false
  },
  "files": {
    "MEMORY.md": { "words": 0, "last_updated": null },
    "debugging.md": { "words": 0, "last_updated": null },
    "patterns.md": { "words": 0, "last_updated": null },
    "architecture.md": { "words": 0, "last_updated": null },
    "preferences.md": { "words": 0, "last_updated": null }
  }
}
EOF
    log_success "Created .memory-index.json"
  
  # 7. Auto-populate from project root if available
  if [ -d "$project" ]; then
    log_info "Auto-populating from project..."
    
    # README.md → architecture.md
    if [ -f "$project/README.md" ]; then
      head -20 "$project/README.md" >> "$memory_dir/architecture.md"
      log_success "Populated architecture.md from README"
    fi
    
    # Recent git history → MEMORY.md
    if [ -d "$project/.git" ]; then
      {
        echo ""
        echo "## Recent Changes"
        cd "$project" && git log --oneline -10 2>/dev/null || true
      } >> "$memory_dir/MEMORY.md"
      log_success "Populated MEMORY.md from git history"
    fi
  fi
  
  echo "$memory_dir"
}

# ============================================================================
# Layer 2: Knowledge Graph (Obsidian)
# ============================================================================

init_knowledge_graph() {
  local project="$1"
  local vault="${LACP_OBSIDIAN_VAULT}"
  
  log_info "Initializing Layer 2 Knowledge Graph..."
  log_info "  Vault: $vault"
  
  if [ ! -d "$vault" ]; then
    mkdir -p "$vault"
    log_success "Created Obsidian vault at $vault"
  fi
  
  # Create vault structure using vault_paths resolver
  local _lib_dir
  _lib_dir="$(dirname "$0")/../lib"
  local _resolve="python3 -c \"import sys; sys.path.insert(0,'$_lib_dir'); from vault_paths import resolve; import sys as s; print(resolve(s.argv[1]))\" 2>/dev/null"

  for _key in projects concepts people systems; do
    local _dir
    _dir=$(eval "$_resolve $_key" || echo "$vault/$_key")
    mkdir -p "$_dir"
  done
  local _inbox_dir
  _inbox_dir=$(eval "$_resolve inbox" || echo "$vault/inbox")
  mkdir -p "$_inbox_dir/queue-generated"

  # Create index if missing
  local _index_path
  _index_path=$(eval "$_resolve index" || echo "$vault/index.md")
  if [ ! -f "$_index_path" ]; then
    cat > "$_index_path" <<'EOF'
# Knowledge Graph Index

## Projects
- [[projects]]

## Concepts
- [[concepts]]

## People
- [[people]]

## Systems
- [[systems]]

## Inbox
- [[inbox]]
EOF
    log_success "Created vault index"
  fi
  
  log_success "Knowledge graph ready at $vault"
}

# ============================================================================
# Layer 3: Ingestion Pipeline
# ============================================================================

init_ingestion_pipeline() {
  local project="$1"
  local slug
  
  slug=$(path_to_slug "$project")
  local ingest_dir="$SESSION_MEMORY_ROOT/$slug/memory/inbox"
  
  log_info "Initializing Layer 3 Ingestion Pipeline..."
  log_info "  Inbox dir: $ingest_dir"
  
  mkdir -p "$ingest_dir/queue-generated"
  mkdir -p "$ingest_dir/processed"
  
  # Create index
  cat > "$ingest_dir/queue-generated/index.md" <<'EOF'
# Ingestion Queue Index

Auto-generated index of ingested content.
Updated by `openclaw-brain-ingest --poll`.

## Ingested Items
(Items appear here as they are processed)
EOF
  
  log_success "Ingestion pipeline ready at $ingest_dir"
}

# ============================================================================
# Layer 4: Code Intelligence
# ============================================================================

init_code_intelligence() {
  local project="$1"
  local slug
  
  slug=$(path_to_slug "$project")
  local code_graph_dir="$SESSION_MEMORY_ROOT/$slug/code-graph"
  
  log_info "Initializing Layer 4 Code Intelligence..."
  log_info "  Code graph dir: $code_graph_dir"
  
  mkdir -p "$code_graph_dir"
  
  # Check if gitnexus is available
  if command -v gitnexus >/dev/null 2>&1; then
    log_info "GitNexus found, analyzing codebase..."
    cd "$project" && gitnexus analyze --output "$code_graph_dir/codebase.json" 2>/dev/null || {
      log_warn "GitNexus analysis failed, skipping"
    }
  else
    log_warn "GitNexus not installed (optional). Install with: npm install -g gitnexus"
  fi
  
  # Create placeholder
  cat > "$code_graph_dir/symbols.json" <<'EOF'
{
  "symbols": [],
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "source": "code-intelligence-layer"
}
EOF
  
  log_success "Code intelligence ready at $code_graph_dir"
}

# ============================================================================
# Layer 5: Provenance
# ============================================================================

init_provenance() {
  local project="$1"
  local agent="${2:-unknown}"
  local slug
  
  slug=$(path_to_slug "$project")
  local provenance_dir="$SESSION_MEMORY_ROOT/$slug/provenance"
  
  log_info "Initializing Layer 5 Provenance..."
  log_info "  Provenance dir: $provenance_dir"
  
  mkdir -p "$provenance_dir"
  
  # Create agent registry
  local agent_id=$(openssl rand -hex 16)
  
  cat > "$provenance_dir/agent-identity.json" <<EOF
{
  "agent_id": "$agent_id",
  "agent_name": "$agent",
  "hostname": "$(hostname)",
  "project": "$project",
  "slug": "$slug",
  "registered_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "signing_key_store": "keychain",
  "status": "active"
}
EOF
  
  # Create chain log
  cat > "$provenance_dir/chain.jsonl" <<'EOF'
# Provenance chain log
# Each line is a JSON receipt with SHA-256 hash chain
EOF
  
  log_success "Provenance initialized"
  log_info "Agent ID: $agent_id"
}

# ============================================================================
# Doctor: Health Check
# ============================================================================

doctor() {
  local project="${1:-.}"
  local slug
  
  slug=$(path_to_slug "$project")
  local memory_dir="$SESSION_MEMORY_ROOT/$slug/memory"
  
  log_info "Health check for project: $project"
  
  # Layer 1
  echo ""
  echo -e "${BLUE}Layer 1: Session Memory${NC}"
  for file in MEMORY.md debugging.md patterns.md architecture.md preferences.md; do
    if [ -f "$memory_dir/$file" ]; then
      echo -e "${GREEN}✓${NC} $file"
    else
      echo -e "${RED}✗${NC} $file (missing)"
    fi
  done
  
  # Layer 2
  echo ""
  echo -e "${BLUE}Layer 2: Knowledge Graph${NC}"
  if [ -d "$LACP_OBSIDIAN_VAULT" ]; then
    echo -e "${GREEN}✓${NC} Obsidian vault exists"
  else
    echo -e "${YELLOW}○${NC} Obsidian vault not initialized"
  fi
  
  # Layer 3
  echo ""
  echo -e "${BLUE}Layer 3: Ingestion Pipeline${NC}"
  if [ -d "$memory_dir/inbox/queue-generated" ]; then
    echo -e "${GREEN}✓${NC} Ingestion pipeline ready"
  else
    echo -e "${RED}✗${NC} Ingestion pipeline not initialized"
  fi
  
  # Layer 4
  echo ""
  echo -e "${BLUE}Layer 4: Code Intelligence${NC}"
  if [ -d "$SESSION_MEMORY_ROOT/$slug/code-graph" ]; then
    echo -e "${GREEN}✓${NC} Code intelligence ready"
  else
    echo -e "${YELLOW}○${NC} Code intelligence not initialized"
  fi
  
  # Layer 5
  echo ""
  echo -e "${BLUE}Layer 5: Provenance${NC}"
  if [ -f "$SESSION_MEMORY_ROOT/$slug/provenance/agent-identity.json" ]; then
    echo -e "${GREEN}✓${NC} Agent identity registered"
  else
    echo -e "${YELLOW}○${NC} Provenance not initialized"
  fi
  
  echo ""
}

# ============================================================================
# Main
# ============================================================================

usage() {
  cat <<EOF
$PROG v$VERSION — OpenClaw LACP Memory Stack Orchestrator

USAGE:
  $PROG init [OPTIONS]        Initialize all 5 memory layers
  $PROG doctor [PROJECT]      Health check of memory system
  $PROG expand [OPTIONS]      Re-summarize and deduplicate memory
  $PROG help                  Show this help

INIT OPTIONS:
  --project PATH              Project directory (default: current)
  --agent NAME                Agent name (default: unknown)
  --with-obsidian            Initialize Obsidian knowledge graph
  --with-gitnexus            Initialize code intelligence with GitNexus
  --auto-ingest              Enable automatic ingestion polling

DOCTOR OPTIONS:
  --project PATH              Project directory (default: current)
  --verbose                   Show detailed status

EXPAND OPTIONS:
  --project PATH              Project directory (default: current)
  --layer NUM                 Expand specific layer (1-5)
  --max-tokens NUM            Token budget (default: 5000)

EXAMPLES:
  # Initialize full system
  $PROG init --project ~/repos/easy-api --agent wren --with-obsidian

  # Health check
  $PROG doctor --project ~/repos/easy-api --verbose

  # Expand memory layer
  $PROG expand --project ~/repos/easy-api --layer 1 --max-tokens 8000

EOF
}

main() {
  local cmd="${1:-help}"
  
  case "$cmd" in
    init)
      shift
      local project="."
      local agent="unknown"
      local with_obsidian=0
      local with_gitnexus=0
      local auto_ingest=0
      
      while [ $# -gt 0 ]; do
        case "$1" in
          --project) project="$2"; shift 2 ;;
          --agent) agent="$2"; shift 2 ;;
          --with-obsidian) with_obsidian=1; shift ;;
          --with-gitnexus) with_gitnexus=1; shift ;;
          --auto-ingest) auto_ingest=1; shift ;;
          *) log_error "Unknown option: $1"; exit 1 ;;
        esac
      done
      
      log_info "Initializing OpenClaw LACP Memory Stack v$VERSION"
      echo ""
      
      # Layer 1: Always init
      init_session_memory "$project" "$agent"
      echo ""
      
      # Layer 2: Optional
      if [ $with_obsidian -eq 1 ]; then
        init_knowledge_graph "$project"
        echo ""
      fi

      # Layer 3: Init with obsidian or explicit auto-ingest
      if [ $auto_ingest -eq 1 ] || [ $with_obsidian -eq 1 ]; then
        init_ingestion_pipeline "$project"
        echo ""
      fi
      
      # Layer 4: Optional
      if [ $with_gitnexus -eq 1 ]; then
        init_code_intelligence "$project"
        echo ""
      fi
      
      # Layer 5: Always init
      init_provenance "$project" "$agent"
      echo ""
      
      log_success "Memory stack initialized successfully!"
      ;;
    
    doctor)
      shift
      local project="."
      while [ $# -gt 0 ]; do
        case "$1" in
          --project) project="$2"; shift 2 ;;
          --verbose) shift ;;
          *) shift ;;
        esac
      done
      doctor "$project"
      ;;
    
    expand)
      shift
      exec bash "$(dirname "$0")/engram-brain-expand" "$@"
      ;;
    
    help|--help|-h)
      usage
      ;;
    
    *)
      log_error "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
