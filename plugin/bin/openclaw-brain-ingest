#!/usr/bin/env python3
"""
openclaw-brain-ingest: Layer 3 Ingestion Pipeline
Converts transcripts, URLs, PDFs, and files into structured indexed notes

Usage:
  openclaw-brain-ingest transcript <vault-path> <file> [--speaker <name>] [--date <date>]
  openclaw-brain-ingest url <vault-path> <url> [--title <title>]
  openclaw-brain-ingest pdf <vault-path> <file> [--title <title>]
  openclaw-brain-ingest file <vault-path> <file> [--title <title>]
  openclaw-brain-ingest index <vault-path> [--qmd]
"""

import sys
import json
import argparse
from pathlib import Path
from datetime import datetime
import hashlib

from pathlib import Path as _Path
import sys as _sys
_sys.path.insert(0, str(_Path(__file__).resolve().parent / "lib"))
from mode_check import guard_or_exit

_INGEST_MODE_STATUS = guard_or_exit("brain-ingest", json_output="--json" in _sys.argv)


def ingest_transcript(vault_path, transcript_file, speaker=None, date=None):
    """Ingest a transcript file"""
    vault = Path(vault_path)
    inbox = vault / "inbox" / "queue-generated"
    inbox.mkdir(parents=True, exist_ok=True)
    # In connected mode, force all writes to the agent inbox queue
    if _INGEST_MODE_STATUS == "redirected_to_inbox":
        from mode import get_inbox_queue_path
        inbox = Path(get_inbox_queue_path())
        inbox.mkdir(parents=True, exist_ok=True)

    content = Path(transcript_file).read_text() if Path(transcript_file).exists() else ""
    
    title = f"Transcript — {speaker or 'Unknown'} ({date or 'undated'})"
    slug = "transcript_" + hashlib.md5(title.encode()).hexdigest()[:8]
    
    note = f"""# {title}

## Metadata
- **Type:** Transcript
- **Speaker:** {speaker or 'Unknown'}
- **Date:** {date or 'Unknown'}
- **Ingested:** {datetime.now().isoformat()}

## Content

{content}

---
Ingested by openclaw-brain-ingest
"""
    
    output_file = inbox / f"{slug}.md"
    output_file.write_text(note)
    print(f"Ingested: {output_file}")
    return str(output_file)


def ingest_url(vault_path, url, title=None):
    """Ingest content from a URL"""
    vault = Path(vault_path)
    inbox = vault / "inbox" / "queue-generated"
    inbox.mkdir(parents=True, exist_ok=True)
    # In connected mode, force all writes to the agent inbox queue
    if _INGEST_MODE_STATUS == "redirected_to_inbox":
        from mode import get_inbox_queue_path
        inbox = Path(get_inbox_queue_path())
        inbox.mkdir(parents=True, exist_ok=True)

    title = title or url
    slug = "url_" + hashlib.md5(url.encode()).hexdigest()[:8]
    
    note = f"""# {title}

## Metadata
- **Type:** URL
- **Source:** [{url}]({url})
- **Ingested:** {datetime.now().isoformat()}

## Content

(Content would be fetched from URL)

---
Ingested by openclaw-brain-ingest
"""
    
    output_file = inbox / f"{slug}.md"
    output_file.write_text(note)
    print(f"Ingested: {output_file}")
    return str(output_file)


def ingest_pdf(vault_path, pdf_file, title=None):
    """Ingest a PDF file"""
    vault = Path(vault_path)
    inbox = vault / "inbox" / "queue-generated"
    inbox.mkdir(parents=True, exist_ok=True)
    # In connected mode, force all writes to the agent inbox queue
    if _INGEST_MODE_STATUS == "redirected_to_inbox":
        from mode import get_inbox_queue_path
        inbox = Path(get_inbox_queue_path())
        inbox.mkdir(parents=True, exist_ok=True)

    pdf_name = Path(pdf_file).name
    title = title or Path(pdf_file).stem
    slug = "pdf_" + hashlib.md5(pdf_file.encode()).hexdigest()[:8]
    
    note = f"""# {title}

## Metadata
- **Type:** PDF
- **Filename:** `{pdf_name}`
- **Ingested:** {datetime.now().isoformat()}

## Content

(PDF text would be extracted here)

---
Ingested by openclaw-brain-ingest
"""
    
    output_file = inbox / f"{slug}.md"
    output_file.write_text(note)
    print(f"Ingested: {output_file}")
    return str(output_file)


def ingest_file(vault_path, file_path, title=None):
    """Ingest a generic file"""
    vault = Path(vault_path)
    inbox = vault / "inbox" / "queue-generated"
    inbox.mkdir(parents=True, exist_ok=True)
    # In connected mode, force all writes to the agent inbox queue
    if _INGEST_MODE_STATUS == "redirected_to_inbox":
        from mode import get_inbox_queue_path
        inbox = Path(get_inbox_queue_path())
        inbox.mkdir(parents=True, exist_ok=True)

    file_obj = Path(file_path)
    content = file_obj.read_text(errors='ignore') if file_obj.exists() else ""
    
    title = title or file_obj.stem
    slug = "file_" + hashlib.md5(file_path.encode()).hexdigest()[:8]
    
    note = f"""# {title}

## Metadata
- **Type:** File
- **Filename:** `{file_obj.name}`
- **Ingested:** {datetime.now().isoformat()}

## Content

{content[:2000]}

---
Ingested by openclaw-brain-ingest
"""
    
    output_file = inbox / f"{slug}.md"
    output_file.write_text(note)
    print(f"Ingested: {output_file}")
    return str(output_file)


def index_vault(vault_path, update_qmd=False):
    """Rebuild vault index"""
    vault = Path(vault_path)
    inbox = vault / "inbox" / "queue-generated"
    
    # Find all .md files
    files = list(inbox.glob("*.md"))
    
    # Build index
    index_content = "# Ingested Notes Index\n\nAuto-generated.\n\n"
    for f in sorted(files):
        if f.name != "index.md":
            index_content += f"- [{f.stem}]({f.name})\n"
    
    (inbox / "index.md").write_text(index_content)
    print(f"Indexed: {inbox / 'index.md'}")
    
    if update_qmd:
        print("Note: QMD update would run here")


def main():
    parser = argparse.ArgumentParser(description="Ingest content into knowledge graph")
    subparsers = parser.add_subparsers(dest="command", required=True)
    
    # Transcript
    trans_parser = subparsers.add_parser("transcript")
    trans_parser.add_argument("vault_path")
    trans_parser.add_argument("transcript_file")
    trans_parser.add_argument("--speaker")
    trans_parser.add_argument("--date")
    
    # URL
    url_parser = subparsers.add_parser("url")
    url_parser.add_argument("vault_path")
    url_parser.add_argument("url")
    url_parser.add_argument("--title")
    
    # PDF
    pdf_parser = subparsers.add_parser("pdf")
    pdf_parser.add_argument("vault_path")
    pdf_parser.add_argument("pdf_file")
    pdf_parser.add_argument("--title")
    
    # File
    file_parser = subparsers.add_parser("file")
    file_parser.add_argument("vault_path")
    file_parser.add_argument("file_path")
    file_parser.add_argument("--title")
    
    # Index
    index_parser = subparsers.add_parser("index")
    index_parser.add_argument("vault_path")
    index_parser.add_argument("--qmd", action="store_true")
    
    args = parser.parse_args()
    
    if args.command == "transcript":
        ingest_transcript(args.vault_path, args.transcript_file, args.speaker, args.date)
    elif args.command == "url":
        ingest_url(args.vault_path, args.url, args.title)
    elif args.command == "pdf":
        ingest_pdf(args.vault_path, args.pdf_file, args.title)
    elif args.command == "file":
        ingest_file(args.vault_path, args.file_path, args.title)
    elif args.command == "index":
        index_vault(args.vault_path, args.qmd)


if __name__ == "__main__":
    main()
