#!/usr/bin/env bash
#
# openclaw-brain-expand — Re-summarize, deduplicate, and compress memory layers
# Manages memory size by consolidating and archiving stale entries
#

set -euo pipefail

PROG=$(basename "$0")
VERSION="1.0.0"

SESSION_MEMORY_ROOT="${SESSION_MEMORY_ROOT:-$HOME/.openclaw/projects}"

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $*" >&2; }
log_success() { echo -e "${GREEN}[✓]${NC} $*" >&2; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $*" >&2; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }

path_to_slug() {
  local path="$1"
  path="${path/#\~/$HOME}"
  path="$(cd "$path" 2>/dev/null && pwd)" || path="$1"
  slug=$(echo "$path" | sed 's|^/||; s|/|-|g; s|-$||')
  echo "$slug"
}

# ============================================================================
# Deduplication
# ============================================================================

deduplicate_memory() {
  local file="$1"

  if [ ! -f "$file" ]; then
    return
  fi

  local original_lines
  original_lines=$(wc -l < "$file" | tr -d ' ')

  # Remove exact duplicate lines (preserving order)
  local tmp_file
  tmp_file=$(mktemp)
  awk '!seen[$0]++' "$file" > "$tmp_file"
  mv "$tmp_file" "$file"

  local new_lines
  new_lines=$(wc -l < "$file" | tr -d ' ')

  local removed=$((original_lines - new_lines))
  if [ "$removed" -gt 0 ]; then
    echo "  Removed $removed duplicate lines from $(basename "$file")"
  fi
}

# ============================================================================
# Archive old entries
# ============================================================================

archive_old_entries() {
  local memory_dir="$1"
  local max_age_days="${2:-90}"

  local archive_dir="$memory_dir/archive"
  mkdir -p "$archive_dir"

  local archived=0

  # Archive entries older than max_age_days from debugging.md and patterns.md
  for file in "$memory_dir/debugging.md" "$memory_dir/patterns.md"; do
    if [ ! -f "$file" ]; then
      continue
    fi

    local basename
    basename=$(basename "$file" .md)

    # Check if file is large enough to warrant archiving (>200 lines)
    local lines
    lines=$(wc -l < "$file" | tr -d ' ')
    if [ "$lines" -gt 200 ]; then
      local archive_file="$archive_dir/${basename}-$(date +%Y%m%d).md"
      cp "$file" "$archive_file"
      # Keep only the last 100 lines + header
      head -5 "$file" > "$file.tmp"
      echo "" >> "$file.tmp"
      echo "---" >> "$file.tmp"
      echo "*Archived older entries on $(date +%Y-%m-%d). See archive/ for history.*" >> "$file.tmp"
      echo "" >> "$file.tmp"
      tail -100 "$file" >> "$file.tmp"
      mv "$file.tmp" "$file"
      ((archived++))
      echo "  Archived $basename ($lines → $(wc -l < "$file" | tr -d ' ') lines)"
    fi
  done

  echo "  Archived $archived files"
}

# ============================================================================
# Compress memory (remove excessive whitespace)
# ============================================================================

compress_memory() {
  local file="$1"

  if [ ! -f "$file" ]; then
    return
  fi

  local original_size
  original_size=$(wc -c < "$file" | tr -d ' ')

  # Remove trailing whitespace on each line
  sed -i '' 's/[[:space:]]*$//' "$file" 2>/dev/null || sed -i 's/[[:space:]]*$//' "$file"

  # Collapse 3+ blank lines into 2
  local tmp_file
  tmp_file=$(mktemp)
  awk 'BEGIN{bl=0} /^$/{bl++; if(bl<=2) print; next} {bl=0; print}' "$file" > "$tmp_file"
  mv "$tmp_file" "$file"

  local new_size
  new_size=$(wc -c < "$file" | tr -d ' ')
  local saved=$((original_size - new_size))

  if [ "$saved" -gt 0 ]; then
    echo "  Compressed $(basename "$file"): saved $saved bytes"
  fi
}

# ============================================================================
# Layer-specific expand
# ============================================================================

expand_layer1() {
  local project="$1"
  local max_tokens="$2"
  local slug
  slug=$(path_to_slug "$project")
  local memory_dir="$SESSION_MEMORY_ROOT/$slug/memory"

  echo ""
  echo -e "${BLUE}Expanding Layer 1: Session Memory${NC}"

  if [ ! -d "$memory_dir" ]; then
    log_error "Memory directory not found: $memory_dir"
    return 1
  fi

  # Deduplicate
  for file in "$memory_dir"/*.md; do
    [ -f "$file" ] && deduplicate_memory "$file"
  done

  # Compress
  for file in "$memory_dir"/*.md; do
    [ -f "$file" ] && compress_memory "$file"
  done

  # Archive if needed
  archive_old_entries "$memory_dir"

  # Report sizes
  echo ""
  echo "  Current sizes:"
  for file in "$memory_dir"/*.md; do
    [ -f "$file" ] && echo "    $(basename "$file"): $(wc -l < "$file" | tr -d ' ') lines, $(wc -c < "$file" | tr -d ' ') bytes"
  done

  log_success "Layer 1 expanded"
}

expand_layer2() {
  local project="$1"
  local max_tokens="$2"

  echo ""
  echo -e "${BLUE}Expanding Layer 2: Knowledge Graph${NC}"

  local vault="${LACP_OBSIDIAN_VAULT:-$HOME/obsidian/vault}"
  if [ ! -d "$vault" ]; then
    log_warn "Obsidian vault not found"
    return 0
  fi

  local inbox="$vault/05_Inbox/queue-generated"
  if [ -d "$inbox" ]; then
    local count
    count=$(find "$inbox" -name "*.md" -not -name "index.md" 2>/dev/null | wc -l | tr -d ' ')
    echo "  Inbox notes: $count"
  fi

  log_success "Layer 2 expanded"
}

expand_layer3() {
  local project="$1"
  local max_tokens="$2"
  local slug
  slug=$(path_to_slug "$project")
  local ingest_dir="$SESSION_MEMORY_ROOT/$slug/memory/inbox"

  echo ""
  echo -e "${BLUE}Expanding Layer 3: Ingestion Pipeline${NC}"

  if [ ! -d "$ingest_dir" ]; then
    log_warn "Ingestion not initialized"
    return 0
  fi

  # Rebuild index
  local queue_dir="$ingest_dir/queue-generated"
  if [ -d "$queue_dir" ]; then
    local index_content="# Ingested Notes Index\n\nAuto-generated by openclaw-brain-expand on $(date +%Y-%m-%d).\n\n"
    for f in "$queue_dir"/*.md; do
      [ -f "$f" ] && [ "$(basename "$f")" != "index.md" ] && index_content+="- [$(basename "$f" .md)]($(basename "$f"))\n"
    done
    echo -e "$index_content" > "$queue_dir/index.md"
    echo "  Rebuilt index"
  fi

  log_success "Layer 3 expanded"
}

expand_layer5() {
  local project="$1"
  local max_tokens="$2"
  local slug
  slug=$(path_to_slug "$project")

  echo ""
  echo -e "${BLUE}Expanding Layer 5: Provenance${NC}"

  local provenance_root="${PROVENANCE_ROOT:-$HOME/.openclaw/provenance}"
  local chain_file="$provenance_root/$slug/chain.jsonl"

  if [ -f "$chain_file" ]; then
    local count
    count=$(grep -v '^#' "$chain_file" | grep -v '^$' | wc -l | tr -d ' ')
    echo "  Chain length: $count receipts"
    local size
    size=$(wc -c < "$chain_file" | tr -d ' ')
    echo "  Chain size: $size bytes"
  else
    log_warn "No provenance chain"
  fi

  log_success "Layer 5 expanded"
}

# ============================================================================
# Main
# ============================================================================

usage() {
  cat <<EOF
$PROG v$VERSION — Memory Expansion & Maintenance

USAGE:
  $PROG [OPTIONS]

OPTIONS:
  --project PATH        Project directory (default: current)
  --layer NUM           Expand specific layer (1-5, default: all)
  --max-tokens NUM      Token budget for summaries (default: 5000)
  --archive-days NUM    Archive entries older than N days (default: 90)
  --dry-run             Show what would be done without changes
  --help                Show this help

EXAMPLES:
  # Expand all layers
  $PROG --project ~/repos/easy-api

  # Expand just Layer 1 with custom token budget
  $PROG --project ~/repos/easy-api --layer 1 --max-tokens 8000

  # Archive old entries
  $PROG --project ~/repos/easy-api --archive-days 60

EOF
}

main() {
  local project="."
  local layer=""
  local max_tokens=5000
  local archive_days=90
  local dry_run=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --layer) layer="$2"; shift 2 ;;
      --max-tokens) max_tokens="$2"; shift 2 ;;
      --archive-days) archive_days="$2"; shift 2 ;;
      --dry-run) dry_run=1; shift ;;
      --help|-h|help) usage; exit 0 ;;
      *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
  done

  log_info "OpenClaw Brain Expand v$VERSION"
  log_info "Project: $project"
  log_info "Max tokens: $max_tokens"

  if [ "$dry_run" = "1" ]; then
    log_warn "DRY RUN — no changes will be made"
  fi

  if [ -z "$layer" ] || [ "$layer" = "1" ]; then
    expand_layer1 "$project" "$max_tokens"
  fi

  if [ -z "$layer" ] || [ "$layer" = "2" ]; then
    expand_layer2 "$project" "$max_tokens"
  fi

  if [ -z "$layer" ] || [ "$layer" = "3" ]; then
    expand_layer3 "$project" "$max_tokens"
  fi

  if [ -z "$layer" ] || [ "$layer" = "5" ]; then
    expand_layer5 "$project" "$max_tokens"
  fi

  echo ""
  log_success "Expansion complete"
}

main "$@"
