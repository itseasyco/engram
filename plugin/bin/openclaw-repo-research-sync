#!/usr/bin/env bash
#
# openclaw-repo-research-sync — Mirror repository docs into knowledge graph
# Syncs README, docs/, wiki, and code comments into the Obsidian vault
#

set -euo pipefail

PROG=$(basename "$0")
VERSION="1.0.0"

LACP_OBSIDIAN_VAULT="${LACP_OBSIDIAN_VAULT:-$HOME/obsidian/vault}"
SESSION_MEMORY_ROOT="${SESSION_MEMORY_ROOT:-$HOME/.openclaw/projects}"

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $*" >&2; }
log_success() { echo -e "${GREEN}[✓]${NC} $*" >&2; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $*" >&2; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }

path_to_slug() {
  local path="$1"
  path="${path/#\~/$HOME}"
  path="$(cd "$path" 2>/dev/null && pwd)" || path="$1"
  slug=$(echo "$path" | sed 's|^/||; s|/|-|g; s|-$||')
  echo "$slug"
}

# ============================================================================
# Sync README
# ============================================================================

sync_readme() {
  local project_dir="$1"
  local vault_dir="$2"

  log_info "Syncing README files..."

  local synced=0
  for readme in "$project_dir"/README* "$project_dir"/readme*; do
    [ -f "$readme" ] || continue
    local basename
    basename=$(basename "$readme")
    cp "$readme" "$vault_dir/$basename"
    ((synced++))
  done

  log_success "Synced $synced README files"
}

# ============================================================================
# Sync docs/ directory
# ============================================================================

sync_docs() {
  local project_dir="$1"
  local vault_dir="$2"

  log_info "Syncing docs/ directory..."

  local docs_dir="$project_dir/docs"
  if [ ! -d "$docs_dir" ]; then
    log_warn "No docs/ directory found"
    return 0
  fi

  local docs_vault="$vault_dir/docs"
  mkdir -p "$docs_vault"

  local synced=0
  while IFS= read -r doc; do
    local relpath
    relpath="${doc#"$docs_dir"/}"
    local dest="$docs_vault/$relpath"
    mkdir -p "$(dirname "$dest")"
    cp "$doc" "$dest"
    ((synced++))
  done < <(find "$docs_dir" -name "*.md" -type f 2>/dev/null)

  log_success "Synced $synced doc files"
}

# ============================================================================
# Sync CHANGELOG
# ============================================================================

sync_changelog() {
  local project_dir="$1"
  local vault_dir="$2"

  log_info "Syncing CHANGELOG..."

  for changelog in "$project_dir"/CHANGELOG* "$project_dir"/changelog*; do
    [ -f "$changelog" ] || continue
    cp "$changelog" "$vault_dir/$(basename "$changelog")"
    log_success "Synced $(basename "$changelog")"
    return 0
  done

  log_warn "No CHANGELOG found"
}

# ============================================================================
# Extract code comments (top-level docstrings)
# ============================================================================

extract_code_comments() {
  local project_dir="$1"
  local vault_dir="$2"

  log_info "Extracting code comments..."

  local comments_file="$vault_dir/code-comments.md"
  {
    echo "# Code Comments & Docstrings"
    echo ""
    echo "Auto-extracted from source on $(date +%Y-%m-%d)."
    echo ""

    # Python docstrings
    local py_count=0
    while IFS= read -r pyfile; do
      local relpath="${pyfile#"$project_dir"/}"
      local docstring
      docstring=$(head -30 "$pyfile" | awk '/^"""/{found=1} found; /^"""/ && found>1{exit}' 2>/dev/null || true)
      if [ -n "$docstring" ]; then
        echo "## \`$relpath\`"
        echo ""
        echo '```python'
        echo "$docstring"
        echo '```'
        echo ""
        ((py_count++))
      fi
    done < <(find "$project_dir" -name "*.py" -not -path "*/node_modules/*" -not -path "*/.git/*" 2>/dev/null | head -50)

    # JS/TS top-level comments
    local js_count=0
    while IFS= read -r jsfile; do
      local relpath="${jsfile#"$project_dir"/}"
      local comment
      comment=$(head -10 "$jsfile" | grep -E '^\s*(//|/\*|\*)' 2>/dev/null || true)
      if [ -n "$comment" ]; then
        echo "## \`$relpath\`"
        echo ""
        echo '```javascript'
        echo "$comment"
        echo '```'
        echo ""
        ((js_count++))
      fi
    done < <(find "$project_dir" -name "*.ts" -o -name "*.js" 2>/dev/null | grep -v node_modules | head -50)

    echo "---"
    echo "Extracted: $py_count Python, $js_count JS/TS files"
  } > "$comments_file"

  log_success "Extracted code comments"
}

# ============================================================================
# Build project index in vault
# ============================================================================

build_vault_index() {
  local vault_dir="$1"
  local project_name="$2"

  local index_file="$vault_dir/index.md"
  {
    echo "# $project_name"
    echo ""
    echo "Auto-synced by openclaw-repo-research-sync on $(date +%Y-%m-%d)."
    echo ""
    echo "## Contents"
    echo ""

    for file in "$vault_dir"/*.md; do
      [ -f "$file" ] || continue
      [ "$(basename "$file")" = "index.md" ] && continue
      echo "- [[$(basename "$file" .md)]]"
    done

    if [ -d "$vault_dir/docs" ]; then
      echo ""
      echo "## Documentation"
      echo ""
      for file in "$vault_dir/docs"/*.md; do
        [ -f "$file" ] || continue
        echo "- [[docs/$(basename "$file" .md)]]"
      done
    fi
  } > "$index_file"

  log_success "Built vault index"
}

# ============================================================================
# Main
# ============================================================================

usage() {
  cat <<EOF
$PROG v$VERSION — Repository Research Sync

Mirrors repository documentation into the Obsidian knowledge graph.

USAGE:
  $PROG [OPTIONS]

OPTIONS:
  --project PATH            Repository directory (default: current)
  --vault PATH              Obsidian vault path (default: \$LACP_OBSIDIAN_VAULT)
  --include-comments        Also extract code comments/docstrings
  --dry-run                 Show what would be synced
  --help                    Show this help

WHAT GETS SYNCED:
  - README.md and variants
  - docs/ directory (all .md files)
  - CHANGELOG.md
  - Code comments (with --include-comments)

EXAMPLES:
  # Sync current repo to vault
  $PROG

  # Sync specific project
  $PROG --project ~/repos/easy-api

  # Include code comments
  $PROG --project ~/repos/easy-api --include-comments

EOF
}

main() {
  local project="."
  local vault="$LACP_OBSIDIAN_VAULT"
  local include_comments=0
  local dry_run=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --vault) vault="$2"; shift 2 ;;
      --include-comments) include_comments=1; shift ;;
      --dry-run) dry_run=1; shift ;;
      --help|-h|help) usage; exit 0 ;;
      *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
  done

  # Resolve project path
  project="$(cd "$project" 2>/dev/null && pwd)" || project="$1"

  local slug
  slug=$(path_to_slug "$project")
  local project_name
  project_name=$(basename "$project")

  log_info "Repository Research Sync v$VERSION"
  log_info "Project: $project ($slug)"
  log_info "Vault: $vault"

  if [ ! -d "$vault" ]; then
    log_error "Vault not found at $vault. Run 'openclaw-brain-graph init' first."
    exit 1
  fi

  local vault_dir="$vault/01_Projects/$slug"
  mkdir -p "$vault_dir"

  if [ "$dry_run" = "1" ]; then
    log_warn "DRY RUN — listing what would be synced:"
    [ -f "$project/README.md" ] && echo "  README.md"
    [ -d "$project/docs" ] && echo "  docs/ ($(find "$project/docs" -name "*.md" | wc -l | tr -d ' ') files)"
    [ -f "$project/CHANGELOG.md" ] && echo "  CHANGELOG.md"
    return 0
  fi

  sync_readme "$project" "$vault_dir"
  sync_docs "$project" "$vault_dir"
  sync_changelog "$project" "$vault_dir"

  if [ "$include_comments" = "1" ]; then
    extract_code_comments "$project" "$vault_dir"
  fi

  build_vault_index "$vault_dir" "$project_name"

  echo ""
  log_success "Repository synced to vault: $vault_dir"
}

main "$@"
