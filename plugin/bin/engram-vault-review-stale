#!/usr/bin/env python3
"""
engram-vault-review-stale — Process stale notes sitting in inbox/review-stale/.

The staleness scanner (curator step 4) moves notes into review-stale/ but
nothing processes them afterward. This command:

1. Removes timestamp-suffix duplicates (created by staleness scanner collisions)
2. Re-classifies each note using inbox_processor's category inference
3. Routes notes to the correct vault folder or archive
4. Optionally uses QMD semantic search to check for superseded content

Usage:
  engram vault review-stale [--dry-run] [--auto] [--limit N]
"""

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path


# ── Colors ──────────────────────────────────────────────────────────────────
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
RED = "\033[0;31m"
CYAN = "\033[0;36m"
BOLD = "\033[1m"
DIM = "\033[2m"
NC = "\033[0m"

# ── Resolve vault ───────────────────────────────────────────────────────────

def resolve_vault() -> Path:
    """Find the vault root from env vars or engram config."""
    for var in ("LACP_OBSIDIAN_VAULT", "OPENCLAW_VAULT", "OPENCLAW_VAULT_ROOT"):
        val = os.environ.get(var)
        if val and Path(val).is_dir():
            return Path(val)

    env_file = Path.home() / ".openclaw/extensions/engram/config/.engram.env"
    if env_file.is_file():
        for line in env_file.read_text().splitlines():
            line = line.strip()
            if line.startswith("LACP_OBSIDIAN_VAULT="):
                val = line.split("=", 1)[1].strip().strip('"').strip("'")
                if Path(val).is_dir():
                    return Path(val)

    return Path.home() / ".openclaw/data/knowledge"


# ── Frontmatter parsing ────────────────────────────────────────────────────

def parse_frontmatter(content: str) -> dict:
    """Quick YAML frontmatter parser (no PyYAML dependency)."""
    if not content.startswith("---"):
        return {}
    end = content.find("---", 3)
    if end == -1:
        return {}
    fm = {}
    for line in content[3:end].strip().split("\n"):
        if ":" in line:
            key, val = line.split(":", 1)
            key = key.strip()
            val = val.strip().strip('"').strip("'")
            if val.startswith("[") and val.endswith("]"):
                val = [v.strip().strip('"').strip("'") for v in val[1:-1].split(",") if v.strip()]
            fm[key] = val
    return fm


def get_body(content: str) -> str:
    """Get content after frontmatter."""
    if not content.startswith("---"):
        return content
    end = content.find("---", 3)
    if end == -1:
        return content
    return content[end + 3:]


# ── Structural type detection ──────────────────────────────────────────────
# Detect note type by content structure BEFORE keyword matching.
# This catches meetings, daily notes, session logs, etc. that have
# recognizable patterns regardless of their topic keywords.

MEETING_MARKERS = [
    ("**Attendees:**", "**Duration:**"),
    ("Attendees:", "Duration:"),
    ("**Participants:**", "**Duration:**"),
]

DAILY_NOTE_RE = re.compile(r'^# \d{4}-\d{2}-\d{2}')
SESSION_MARKERS = ["## Session", "## First Session", "came online", "woke up"]
PRD_MARKERS = ["## Requirements", "## User Stories", "## Acceptance Criteria", "PRD", "Product Requirements"]

# ── Team roster (for meeting sub-classification) ──────────────────────────
# These are internal team members — everyone else is "external"
TEAM_MEMBERS = {
    "niko lemieux", "andrew fisher", "evan goldberg", "ari shaller",
    "chad green", "danie beukman",
}

# Bot/notetaker patterns — always ignored when counting external attendees
NOTETAKER_PATTERNS = [
    "notetaker", "fireflies", "read.ai", "circleback", "otter.ai",
    "participant ",  # anonymous/unnamed participants
]

# Keywords that signal investor context
INVESTOR_KEYWORDS = [
    "investor", "fundrais", "pitch", "valuation", "safe", "term sheet",
    "cap table", "round", "pre-seed", "seed", "series a", "vc ", "venture",
    "deck", "due diligence",
]

# Keywords that signal client/partner context
CLIENT_KEYWORDS = [
    "merchant", "onboard", "settlement", "payment", "processing", "volume",
    "transaction", "integration", "demo", "walkthrough", "pricing",
    "contract", "sow", "pilot",
]


def _is_internal(name: str) -> bool:
    """Check if a meeting participant is internal team or a bot."""
    n = name.lower().strip()
    if n in TEAM_MEMBERS:
        return True
    for pat in NOTETAKER_PATTERNS:
        if pat in n:
            return True
    return False


def classify_meeting(title: str, body: str, attendees_raw: str) -> str:
    """
    Sub-classify a meeting by context: team, investor, client, conference, personal.
    Returns a meetings subfolder name.
    """
    attendees = [a.strip() for a in attendees_raw.split(",") if a.strip()]
    external = [a for a in attendees if not _is_internal(a)]

    title_lower = title.lower()
    content_lower = body[:3000].lower()

    # Large meetings = conference/group calls
    if len(attendees) > 15:
        return "meetings/conference"

    # Personal
    if "family" in title_lower or "personal" in title_lower:
        return "meetings/personal"

    # All internal = team meeting
    if len(external) == 0:
        return "meetings/team"

    # Check content for investor signals
    if any(kw in content_lower for kw in INVESTOR_KEYWORDS):
        return "meetings/investors"

    # Check content for client/partner signals
    if any(kw in content_lower for kw in CLIENT_KEYWORDS):
        return "meetings/clients"

    # External meeting that doesn't match investor or client
    return "meetings/external"


def detect_note_type(title: str, body: str, fm: dict) -> str | None:
    """
    Detect note type by structural patterns. Returns a category/folder string
    or None if no structural match (falls through to keyword matching).
    """
    content = body[:3000]  # only scan first 3000 chars for structure

    # ── Meetings (Circleback, Otter, etc.) ────────────────────────────
    attendees_raw = None
    for attendee_marker, duration_marker in MEETING_MARKERS:
        if attendee_marker in content and duration_marker in content:
            # Extract attendees line for sub-classification
            m = re.search(re.escape(attendee_marker) + r'\s*(.+?)(?:\n|$)', content)
            if m:
                attendees_raw = m.group(1)
            break

    # Also catch by title pattern
    if not attendees_raw and re.match(r'^\d{4}[\s-]\d{2}[\s-]\d{2}[\s-]', title):
        m = re.search(r'Attendees:\s*(.+?)(?:\n|$)', content)
        if m:
            attendees_raw = m.group(1)

    if attendees_raw is not None:
        return classify_meeting(title, content, attendees_raw)

    # ── Agent session/daily notes ─────────────────────────────────────
    if DAILY_NOTE_RE.match(body.strip()):
        for marker in SESSION_MARKERS:
            if marker in content:
                return "sessions"

    # ── PRDs ──────────────────────────────────────────────────────────
    prd_hits = sum(1 for m in PRD_MARKERS if m.lower() in content.lower())
    if prd_hits >= 2 or (title.lower().startswith("prd") and prd_hits >= 1):
        return "projects"

    return None


# ── Category inference (keyword-based fallback) ────────────────────────────

CATEGORY_KEYWORDS = {
    "projects": [
        "repo", "repository", "codebase", "pr ", "pull request", "branch",
        "deploy", "feature", "sprint", "backlog", "endpoint",
        "dashboard", "migration", "prd", "spec", "requirements",
    ],
    "engineering": [
        "architecture", "technical", "implementation", "refactor",
        "testing", "performance", "security", "optimization",
        "infrastructure", "server", "database", "deployment", "monitoring",
        "ci/cd", "pipeline", "docker", "kubernetes",
    ],
    "strategy": [
        "vision", "direction", "fundrais", "investor", "partnership",
        "hiring", "growth", "positioning", "branding",
        "roadmap", "milestone", "timeline", "objective",
        "quarter", "okr", "goal", "launch",
    ],
    "research": [
        "evaluation", "comparison", "benchmark", "competitor", "market",
        "analysis", "finding", "research",
    ],
    "people": [
        "role", "responsibility", "contact", "onboard",
        "1:1", "one-on-one", "career", "feedback session",
    ],
    "knowledge": [
        "learning", "concept", "reference", "how-to", "guide",
        "documentation", "pattern", "convention", "best practice",
    ],
}

# Category to vault folder mapping
# Meeting subtypes map to subfolders: meetings/team, meetings/investors, etc.
CATEGORY_FOLDERS = {
    "meetings": "meetings",
    "meetings/team": "meetings/team",
    "meetings/investors": "meetings/investors",
    "meetings/clients": "meetings/clients",
    "meetings/conference": "meetings/conference",
    "meetings/personal": "meetings/personal",
    "meetings/external": "meetings/external",
    "sessions": "sessions",
    "projects": "projects",
    "people": "people",
    "research": "research",
    "strategy": "strategy",
    "engineering": "engineering",
    "knowledge": "knowledge",
    "reference": "reference",
}


def infer_category(title: str, body: str, tags: list, fm: dict) -> str:
    """Infer the best category for a note."""
    # 1. Trust frontmatter category if it's a real folder (not "inbox")
    fm_cat = fm.get("category", "")
    if fm_cat and fm_cat != "inbox" and fm_cat in CATEGORY_FOLDERS:
        return fm_cat

    # 2. Structural detection — catches meetings (with subfolders), sessions, PRDs
    structural = detect_note_type(title, body, fm)
    if structural:
        return structural  # may be "meetings/investors", "sessions", etc.

    # 3. Keyword-based fallback
    text = f"{title} {body}".lower()
    tag_text = " ".join(str(t).lower() for t in (tags if isinstance(tags, list) else []))
    combined = f"{text} {tag_text}"

    scores = {}
    for category, keywords in CATEGORY_KEYWORDS.items():
        score = sum(1 for kw in keywords if kw in combined)
        if score > 0:
            scores[category] = score

    if not scores:
        return "knowledge"  # default

    return max(scores, key=scores.get)


# ── QMD semantic search ────────────────────────────────────────────────────

def qmd_available() -> bool:
    """Check if QMD is installed and actually responsive to search."""
    try:
        result = subprocess.run(
            ["qmd", "search", "test", "--limit", "1", "--json"],
            capture_output=True, text=True, timeout=5
        )
        return result.returncode == 0
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
        return False


def qmd_search(query: str, limit: int = 3) -> list:
    """Run QMD semantic search, return top results."""
    try:
        result = subprocess.run(
            ["qmd", "search", query, "--limit", str(limit), "--json"],
            capture_output=True, text=True, timeout=10
        )
        if result.returncode == 0 and result.stdout.strip():
            data = json.loads(result.stdout)
            if isinstance(data, list):
                return data
    except (subprocess.TimeoutExpired, json.JSONDecodeError, FileNotFoundError):
        pass
    return []


def check_superseded(title: str, body_preview: str) -> dict | None:
    """Check if similar content already exists in the vault."""
    query = title[:100]
    results = qmd_search(query)
    if not results:
        return None

    # Check if any result is a strong match (not from review-stale itself)
    for r in results:
        path = r.get("path", "")
        score = r.get("score", 0)
        if "review-stale" not in path and score > 0.7:
            return {"path": path, "score": score, "title": r.get("title", "")}
    return None


# ── Duplicate detection ────────────────────────────────────────────────────

TIMESTAMP_SUFFIX = re.compile(r'^(.+)-(\d{10})\.md$')


def find_duplicates(stale_dir: Path) -> tuple:
    """
    Find timestamp-suffix duplicates created by staleness scanner collisions.

    Returns (duplicates_to_remove, originals_kept).
    """
    duplicates = []
    originals = set()

    for f in sorted(stale_dir.iterdir()):
        if not f.is_file() or not f.name.endswith(".md"):
            continue
        match = TIMESTAMP_SUFFIX.match(f.name)
        if match:
            base_name = match.group(1) + ".md"
            original = stale_dir / base_name
            if original.exists():
                # Check if the only diff is the title field
                try:
                    orig_content = original.read_text(encoding="utf-8")
                    dup_content = f.read_text(encoding="utf-8")
                    # Strip the title line and compare
                    orig_lines = orig_content.split("\n")
                    dup_lines = dup_content.split("\n")
                    # Find title lines
                    orig_no_title = [l for l in orig_lines if not l.startswith("title:")]
                    dup_no_title = [l for l in dup_lines if not l.startswith("title:")]
                    if orig_no_title == dup_no_title:
                        duplicates.append(f)
                        originals.add(original)
                        continue
                except (IOError, UnicodeDecodeError):
                    pass
            # If no original, this IS the content (just timestamp-named)
            # Keep it but flag it for rename
            duplicates.append(f)
        else:
            originals.add(f)

    return duplicates, originals


# ── Main processing ────────────────────────────────────────────────────────

def process_review_stale(
    vault: Path,
    dry_run: bool = True,
    auto: bool = False,
    limit: int = 0,
    use_qmd: bool = True,
) -> dict:
    """Process all notes in inbox/review-stale/."""

    stale_dir = vault / "inbox" / "review-stale"
    if not stale_dir.exists():
        print(f"  {DIM}No review-stale folder found.{NC}")
        return {"total": 0}

    all_files = sorted(f for f in stale_dir.iterdir() if f.is_file() and f.name.endswith(".md"))
    total = len(all_files)

    print(f"  {BOLD}Found {total} files in inbox/review-stale/{NC}")
    print()

    # ── Phase 1: Remove duplicates ──────────────────────────────────────
    print(f"  {BOLD}{CYAN}Phase 1: Duplicate Detection{NC}")
    duplicates, originals = find_duplicates(stale_dir)

    stats = {
        "total": total,
        "duplicates_removed": 0,
        "classified": {},
        "archived": 0,
        "superseded": 0,
        "moved": 0,
        "skipped": 0,
    }

    if duplicates:
        print(f"  {YELLOW}{len(duplicates)}{NC} timestamp-suffix duplicates (title-only diffs)")
        if dry_run:
            print(f"  {DIM}Would remove {len(duplicates)} duplicates{NC}")
        else:
            if not auto:
                print(f"  Remove {len(duplicates)} duplicates? [Y/n]: ", end="")
                confirm = input().strip()
                if confirm.lower() in ("n", "no"):
                    print(f"  {DIM}Skipped duplicate removal{NC}")
                    duplicates = []

            for dup in duplicates:
                if not dry_run:
                    dup.unlink()
                stats["duplicates_removed"] += 1

            if stats["duplicates_removed"] > 0:
                print(f"  {GREEN}Removed {stats['duplicates_removed']} duplicates{NC}")
    else:
        print(f"  {GREEN}No duplicates found{NC}")
    print()

    # ── Phase 2: Classify and route remaining notes ─────────────────────
    print(f"  {BOLD}{CYAN}Phase 2: Classification & Routing{NC}")

    # Re-scan after duplicate removal
    remaining = sorted(f for f in stale_dir.iterdir() if f.is_file() and f.name.endswith(".md"))
    if limit > 0:
        remaining = remaining[:limit]

    # Auto-disable QMD if not available
    if use_qmd:
        if not qmd_available():
            print(f"  {DIM}QMD not available — skipping semantic search{NC}")
            use_qmd = False
        else:
            print(f"  {DIM}QMD enabled — checking for superseded content{NC}")

    print(f"  {len(remaining)} notes to classify")
    print()

    # First pass: classify everything
    classifications = []
    for f in remaining:
        try:
            content = f.read_text(encoding="utf-8")
        except (IOError, UnicodeDecodeError):
            classifications.append({"file": f, "category": "archive", "reason": "unreadable"})
            continue

        fm = parse_frontmatter(content)
        body = get_body(content)
        title = fm.get("title", f.stem)
        tags = fm.get("tags", [])

        category = infer_category(title, body, tags, fm)
        # For meeting subtypes, category IS the folder path (e.g. "meetings/investors")
        target_folder = CATEGORY_FOLDERS.get(category, category if "/" in category else "knowledge")

        # Check for superseded content via QMD
        superseded_by = None
        if use_qmd and not dry_run:
            superseded_by = check_superseded(title, body[:200])

        classifications.append({
            "file": f,
            "title": title,
            "category": category,
            "target_folder": target_folder,
            "superseded_by": superseded_by,
            "fm": fm,
        })

    # Group by target folder for display
    by_folder = {}
    for c in classifications:
        folder = c["target_folder"]
        if folder not in by_folder:
            by_folder[folder] = []
        by_folder[folder].append(c)

    for folder, notes in sorted(by_folder.items()):
        print(f"  {BOLD}{folder}/{NC} ({len(notes)} notes)")
        stats["classified"][folder] = len(notes)
        for note in notes[:5]:  # show first 5 per category
            superseded = ""
            if note.get("superseded_by"):
                superseded = f"  {DIM}(superseded by: {note['superseded_by']['title']}){NC}"
            print(f"    {note['title']}{superseded}")
        if len(notes) > 5:
            print(f"    {DIM}... and {len(notes) - 5} more{NC}")
    print()

    if dry_run:
        print(f"  {YELLOW}DRY RUN — no files moved. Run without --dry-run to apply.{NC}")
        return stats

    # ── Phase 3: Move files ─────────────────────────────────────────────
    if not auto:
        print(f"  Move {len(classifications)} notes to their target folders? [Y/n]: ", end="")
        confirm = input().strip()
        if confirm.lower() in ("n", "no"):
            print(f"  {DIM}Cancelled{NC}")
            return stats

    print()
    print(f"  {BOLD}{CYAN}Phase 3: Moving Files{NC}")

    # Track moves for link updates: {old_stem: new_relative_path}
    moved_files = {}

    for c in classifications:
        f = c["file"]
        target = vault / c["target_folder"]

        # If superseded and in auto mode, archive instead
        if c.get("superseded_by") and auto:
            target = vault / "archive"
            stats["archived"] += 1
        else:
            stats["moved"] += 1

        target.mkdir(parents=True, exist_ok=True)
        dest = target / f.name
        if dest.exists():
            dest = target / f"{f.stem}-{int(datetime.now(timezone.utc).timestamp())}.md"

        # Update frontmatter status before moving
        try:
            content = f.read_text(encoding="utf-8")
            if "status: review" in content or "status: stale" in content:
                content = content.replace("status: review", "status: active").replace("status: stale", "status: active")
                f.write_text(content, encoding="utf-8")
        except (IOError, UnicodeDecodeError):
            pass

        old_stem = f.stem
        shutil.move(str(f), str(dest))
        moved_files[old_stem] = dest

    print(f"  {GREEN}Moved {stats['moved']} notes to target folders{NC}")
    if stats["archived"] > 0:
        print(f"  {GREEN}Archived {stats['archived']} superseded notes{NC}")

    # ── Phase 4: Update wikilinks ──────────────────────────────────────
    print()
    print(f"  {BOLD}{CYAN}Phase 4: Updating Links{NC}")
    update_wikilinks(vault, moved_files, stats)

    # ── Phase 5: Regenerate inbox index ────────────────────────────────
    print()
    print(f"  {BOLD}{CYAN}Phase 5: Inbox Index{NC}")
    regenerate_inbox_index(vault)

    return stats


# ── Wikilink updater ───────────────────────────────────────────────────────

WIKILINK_RE = re.compile(r'\[\[([^\]|]+)(\|[^\]]+)?\]\]')


def update_wikilinks(vault: Path, moved_files: dict, stats: dict):
    """
    Scan vault for [[wikilinks]] that reference moved files and update them.
    Obsidian uses shortest-unique-path, so [[filename]] works regardless of folder.
    But index files and explicit path references need updating.
    """
    if not moved_files:
        print(f"  {DIM}No moves to update links for{NC}")
        return

    moved_stems = set(moved_files.keys())
    links_updated = 0

    # Only scan index files and files that likely contain cross-references
    index_files = list(vault.rglob("index.md")) + list(vault.rglob("review-queue.md"))

    for idx_file in index_files:
        try:
            content = idx_file.read_text(encoding="utf-8")
        except (IOError, UnicodeDecodeError):
            continue

        original = content
        found_stale = []

        for match in WIKILINK_RE.finditer(content):
            link_target = match.group(1).strip()
            # Check if this link points to a moved file
            link_stem = link_target.rsplit("/", 1)[-1]  # strip any path prefix
            if link_stem in moved_stems:
                found_stale.append(link_stem)

        if found_stale:
            # Remove lines containing stale links from index files
            # (they'll be re-indexed by the curator on next run)
            lines = content.split("\n")
            new_lines = []
            removed = 0
            for line in lines:
                stale = False
                for stem in found_stale:
                    if f"[[{stem}]]" in line or f"[[{stem}|" in line:
                        stale = True
                        removed += 1
                        break
                if not stale:
                    new_lines.append(line)

            if removed > 0:
                idx_file.write_text("\n".join(new_lines), encoding="utf-8")
                links_updated += removed
                print(f"  {GREEN}cleaned{NC}  {idx_file.relative_to(vault)} ({removed} stale links removed)")

    stats["links_updated"] = links_updated
    if links_updated == 0:
        print(f"  {GREEN}No stale links found in index files{NC}")


# ── Inbox index regeneration ──────────────────────────────────────────────

def regenerate_inbox_index(vault: Path):
    """Regenerate the inbox/index.md to reflect current state."""
    inbox = vault / "inbox"
    index_file = inbox / "index.md"

    if not inbox.exists():
        return

    # Count actual files in inbox (excluding subdirectories' contents)
    direct_files = [f for f in inbox.iterdir() if f.is_file() and f.suffix == ".md" and f.name != "index.md"]
    queue_dirs = [d for d in inbox.iterdir() if d.is_dir()]

    now = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")

    lines = [
        "---",
        "type: folder-index",
        f'generated: "{now}"',
        "---",
        "",
        "# inbox",
        "",
        "Incoming notes awaiting classification",
        "",
        f"**{len(direct_files)} notes** | Last updated: {now}",
        "",
    ]

    if direct_files:
        lines.append("## Notes")
        lines.append("")
        for f in sorted(direct_files, key=lambda x: x.stem):
            lines.append(f"- [[{f.stem}]] -- {f.stem.replace('-', ' ').title()}")
        lines.append("")

    for qdir in sorted(queue_dirs):
        queue_files = list(qdir.glob("*.md"))
        if queue_files:
            lines.append(f"## {qdir.name}")
            lines.append("")
            for f in sorted(queue_files, key=lambda x: x.stem):
                lines.append(f"- [[{f.stem}]] -- {f.stem.replace('-', ' ').title()}")
            lines.append("")

    index_file.write_text("\n".join(lines) + "\n", encoding="utf-8")
    print(f"  {GREEN}Regenerated{NC}  inbox/index.md ({len(direct_files)} notes, {len(queue_dirs)} queues)")


# ── CLI ─────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Process stale notes from inbox/review-stale/"
    )
    parser.add_argument("--dry-run", action="store_true", help="Preview without changes")
    parser.add_argument("--auto", action="store_true", help="Non-interactive mode (for heartbeat/cron)")
    parser.add_argument("--limit", type=int, default=0, help="Process only first N notes")
    parser.add_argument("--no-qmd", action="store_true", help="Skip QMD semantic search")
    parser.add_argument("--vault", type=str, help="Override vault path")

    args = parser.parse_args()

    vault = Path(args.vault) if args.vault else resolve_vault()
    if not vault.is_dir():
        print(f"{RED}Vault not found: {vault}{NC}")
        sys.exit(1)

    print()
    print(f"  {BOLD}{CYAN}Engram Vault: Review Stale Notes{NC}")
    print(f"  {DIM}Vault: {vault}{NC}")
    print()

    stats = process_review_stale(
        vault=vault,
        dry_run=args.dry_run,
        auto=args.auto,
        limit=args.limit,
        use_qmd=not args.no_qmd,
    )

    print()
    print(f"  {BOLD}Summary{NC}")
    print(f"    Total:              {stats.get('total', 0)}")
    print(f"    Duplicates removed: {stats.get('duplicates_removed', 0)}")
    print(f"    Moved to folders:   {stats.get('moved', 0)}")
    print(f"    Archived:           {stats.get('archived', 0)}")
    print(f"    Links cleaned:      {stats.get('links_updated', 0)}")
    if stats.get("classified"):
        print(f"    Classification:")
        for folder, count in sorted(stats["classified"].items()):
            print(f"      {folder}: {count}")
    print()


if __name__ == "__main__":
    main()
